############################
# SEVERE INFECTION SIGNATURES
############################

severe_signature_list <- list(

  Hyperinflammation = toupper(c(
    "Il1b","Il6","Tnf","Ifng","Cxcl1","Cxcl2","Ccl2"
  )),

  Neutrophil_Activation = toupper(c(
    "S100a8","S100a9","Lcn2","Mpo","Camp",
    "Retnlg","Ngp","Ltf"
  )),

  Interferon_Response = toupper(c(
    "Stat1","Irf7","Isg15","Ifit1","Ifit3",
    "Mx1","Oas1","Oas2","Oas3"
  )),

  Immunosuppression = toupper(c(
    "Il10","Arg1","Pdcd1","Lag3","Ctla4","Socs3"
  )),

  Emergency_Myelopoiesis = toupper(c(
    "Csf3r","Cebpb","Cebpd","Osm","Fpr1"
  )),

  Acute_Phase_Response = toupper(c(
    "Hp","Saa1","Saa2","Orm1","Lrg1"
  )),

  Complement_Coagulation = toupper(c(
    "C3","Cfb","C1qa","F3","Serpine1"
  )),

  Oxidative_Burst = toupper(c(
    "Cybb","Ncf1","Nos2"
  )),

  Inflammasome = toupper(c(
    "Nlrp3","Pycard","Casp1"
  )),

  Adaptive_Immune_Suppression = toupper(c(
    "Cd3d","Cd4","Cd8a","Il7r","H2-Aa","H2-Ab1"
  ))
)

############################
# NORMAL/CONTROLLED RESPONSE
############################

normal_signature_list <- list(

  Controlled_Immune_Response = toupper(c(
    "IL7R","CCR7","LTB","MALAT1"
  )),

  Tcell_Maintenance = toupper(c(
    "CD3D","CD4","CD8A","IL7R","TRBC1"
  )),

  Antigen_Presentation = toupper(c(
    "H2-AA","H2-AB1","CD74","CIITA"
  )),

  Homeostatic_Monocytes = toupper(c(
    "LY86","FCER1G","CSF1R"
  )),

  Resolution_Response = toupper(c(
    "IL10","TGFB1","MRC1"
  )),

  Oxidative_Metabolism = toupper(c(
    "COX5A","NDUFA1","ATP5F1"
  ))
)

############################
# FUNCTION: LOAD DATA
############################

load_data <- function(file){

  df <- read.csv(file, stringsAsFactors = FALSE)

  colnames(df) <- tolower(colnames(df))

  if(!all(c("gene","logfc") %in% colnames(df))){
    stop(paste("Missing required columns in:", file))
  }

  df <- df %>%
    dplyr::select(gene, logfc)

  # FIX FOR CAPITALIZED GENE NAMES
  df$gene <- toupper(as.character(df$gene))

  # ENSURE NUMERIC
  df$logfc <- as.numeric(df$logfc)

  return(df)
}

############################
# FUNCTION: SCORE SIGNATURES
############################

score_signatures <- function(df, sig_list, sample_name, category){

  results <- data.frame()

  for(sig in names(sig_list)){

    genes <- sig_list[[sig]]

    subset_df <- df %>%
      filter(gene %in% genes)

    detected_genes <- nrow(subset_df)

    mean_logFC <- ifelse(
      detected_genes > 0,
      mean(subset_df$logfc, na.rm=TRUE),
      NA
    )

    max_logFC <- ifelse(
      detected_genes > 0,
      max(subset_df$logfc, na.rm=TRUE),
      NA
    )

    severity <- case_when(
      is.na(mean_logFC) ~ "Not Detected",
      mean_logFC >= 4 ~ "Extreme",
      mean_logFC >= 2 ~ "High",
      mean_logFC >= 1 ~ "Moderate",
      mean_logFC > 0 ~ "Mild",
      TRUE ~ "Suppressed"
    )

    temp <- data.frame(
      Sample = sample_name,
      Category = category,
      Signature = sig,
      Genes_Detected = detected_genes,
      Mean_logFC = round(mean_logFC,2),
      Max_logFC = round(max_logFC,2),
      Severity = severity
    )

    results <- rbind(results, temp)
  }

  return(results)
}

############################
# FUNCTION: CLASSIFY GENES
############################

classify_genes <- function(df, sig_list, sample_name, category){

  all_classifications <- data.frame()

  for(sig in names(sig_list)){

    genes <- sig_list[[sig]]

    subset_df <- df %>%
      filter(gene %in% genes)

    if(nrow(subset_df) > 0){

      subset_df$Signature <- sig
      subset_df$Category <- category
      subset_df$Sample <- sample_name

      subset_df$Expression_Class <- case_when(
        subset_df$logfc >= 4 ~ "Extremely Upregulated",
        subset_df$logfc >= 2 ~ "Strongly Upregulated",
        subset_df$logfc >= 1 ~ "Moderately Upregulated",
        subset_df$logfc > 0 ~ "Mildly Upregulated",
        subset_df$logfc <= -2 ~ "Strongly Downregulated",
        subset_df$logfc < 0 ~ "Downregulated",
        TRUE ~ "Neutral"
      )

      all_classifications <- rbind(
        all_classifications,
        subset_df
      )
    }
  }

  return(all_classifications)
}

############################
# PROCESS FILES
############################

all_scores <- data.frame()
all_gene_classes <- data.frame()

for(file in files){

  sample_name <- tools::file_path_sans_ext(
    basename(file)
  )

  cat("Processing:", sample_name, "\n")

  df <- load_data(file)

  severe_scores <- score_signatures(
    df,
    severe_signature_list,
    sample_name,
    "Severe_Response"
  )

  normal_scores <- score_signatures(
    df,
    normal_signature_list,
    sample_name,
    "Normal_Response"
  )

  severe_gene_classes <- classify_genes(
    df,
    severe_signature_list,
    sample_name,
    "Severe_Response"
  )

  normal_gene_classes <- classify_genes(
    df,
    normal_signature_list,
    sample_name,
    "Normal_Response"
  )

  all_scores <- rbind(
    all_scores,
    severe_scores,
    normal_scores
  )

  all_gene_classes <- rbind(
    all_gene_classes,
    severe_gene_classes,
    normal_gene_classes
  )
}

############################
# SAVE OUTPUT TABLES
############################

write.csv(
