############################
# RADAR PLOTS
############################

samples <- unique(all_scores$Sample)

for(samp in samples){

  radar_df <- all_scores %>%
    filter(
      Sample == samp,
      Category == "Severe_Response"
    ) %>%
    dplyr::select(Signature, Mean_logFC)

  values <- radar_df$Mean_logFC
  names(values) <- radar_df$Signature

  values[is.na(values)] <- 0

  radar_data <- rbind(
    rep(5, length(values)),
    rep(-2, length(values)),
    values
  )

  colnames(radar_data) <- names(values)

  png(
    paste0(samp, "_Severe_RadarPlot.png"),
    width = 900,
    height = 900
  )

  radarchart(
    radar_data,
    axistype = 1,
    pcol = "red",
    pfcol = alpha("red", 0.3),
    plwd = 3,
    cglcol = "grey",
    cglty = 1,
    axislabcol = "black",
    caxislabels = seq(-2,5,1),
    cglwd = 0.8,
    vlcex = 0.8,
    title = paste(
      "Severe Infection Profile:",
      samp
    )
  )

  dev.off()
}

############################
# OVERALL SEVERITY SCORING
############################

severity_scores <- all_scores %>%
  filter(Category == "Severe_Response") %>%
  group_by(Sample) %>%
  summarise(
    Severe_Score = sum(
      Mean_logFC,
      na.rm=TRUE
    )
  )

normal_scores <- all_scores %>%
  filter(Category == "Normal_Response") %>%
  group_by(Sample) %>%
  summarise(
    Normal_Response_Score = sum(
      Mean_logFC,
      na.rm=TRUE
    )
  )

overall_scores <- merge(
  severity_scores,
  normal_scores,
  by="Sample"
)

overall_scores$Overall_Classification <- case_when(

  overall_scores$Severe_Score >= 25 ~
    "Extreme Systemic Infection",

  overall_scores$Severe_Score >= 15 ~
    "Severe Infection",

  overall_scores$Severe_Score >= 8 ~
    "Moderate Infection",

  overall_scores$Severe_Score >= 3 ~
    "Mild Infection",

  TRUE ~
    "Minimal Infection"
)

############################
# NORMAL VS SEVERE BIAS
############################

overall_scores$Response_Bias <- case_when(

  overall_scores$Severe_Score >
    overall_scores$Normal_Response_Score * 2 ~

    "Strong Severe Inflammatory Bias",

  overall_scores$Normal_Response_Score >
    overall_scores$Severe_Score ~

    "Controlled/Resolving Response",

  TRUE ~

    "Intermediate/Mixed Response"
)

write.csv(
  overall_scores,
  "Overall_Severity_Summary.csv",
  row.names = FALSE
)

############################
# BARPLOT:
# NORMAL VS SEVERE RESPONSE
############################

comparison_df <- overall_scores %>%
  dplyr::select(
    Sample,
    Severe_Score,
    Normal_Response_Score
  )

comparison_melt <- melt(
  comparison_df,
  id.vars = "Sample"
)

ggplot(
  comparison_melt,
  aes(
    x = Sample,
    y = value,
    fill = variable
  )
) +
  geom_bar(
    stat = "identity",
    position = "dodge"
  ) +
  theme_bw() +
  labs(
    title = "Severe vs Normal Immune Response",
    y = "Aggregate Signature Score",
    fill = "Response Type"
  )

