# ============================================================
# HELPERS
# ============================================================

clean_text <- function(x) {
  x <- as.character(x)
  x <- trimws(x)
  x <- x[!is.na(x)]
  x <- x[nzchar(x)]
  unique(x)
}

normalize_token <- function(x) {
  x <- tolower(trimws(as.character(x)))
  x <- x[!is.na(x)]
  x <- x[nzchar(x)]
  x
}

split_terms <- function(x) {
  if (length(x) == 0 || is.null(x) || all(is.na(x))) return(character(0))
  vals <- unlist(strsplit(as.character(x), "\\s*\\|\\s*|\\s*,\\s*"))
  vals <- trimws(vals)
  vals <- vals[!is.na(vals)]
  vals <- vals[nzchar(vals)]
  unique(vals)
}

collapse_terms <- function(x) {
  x <- clean_text(x)
  if (length(x) == 0) return(NA_character_)
  paste(x, collapse = ",")
}

safe_col <- function(df, colname) {
  if (colname %in% names(df)) as.character(df[[colname]]) else rep(NA_character_, nrow(df))
}

read_first_column <- function(path, has_header = TRUE) {
  dat <- read_csv(path, col_names = has_header, show_col_types = FALSE, progress = FALSE)
  if (ncol(dat) < 1) stop("No columns found in file: ", path)

  vals <- clean_text(dat[[1]])
  if (length(vals) == 0) stop("No usable gene symbols found in first column of file: ", path)

  vals
}

first_existing_col <- function(df, candidates) {
  hit <- candidates[candidates %in% names(df)]
  if (length(hit) == 0) return(NULL)
  hit[1]
}

