#!/usr/bin/env Rscript

library(tidyverse)

infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

# ---------- PARSE SIGNIFICANCE ----------
# New mapping:
# 1;0;0 = D2-D0
# 0;1;0 = D7-D2
# 0;0;1 = D7-D0

parse_sig <- function(x) {
  vals <- as.integer(str_split(as.character(x), ";", simplify = FALSE)[[1]])
  vals <- vals[!is.na(vals)]

  if (length(vals) < 3) vals <- c(vals, rep(0, 3 - length(vals)))

  usable <- floor(length(vals) / 3) * 3
  vals <- vals[seq_len(usable)]

  mat <- matrix(vals, ncol = 3, byrow = TRUE)

  tibble(
    sig_D2_D0 = any(mat[, 1] == 1),
    sig_D7_D2 = any(mat[, 2] == 1),
    sig_D7_D0 = any(mat[, 3] == 1)
  )
}

# ---------- LOAD ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    profile_id = row_number(),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7)
  ) %>%
  bind_cols(map_dfr(.$Sig, parse_sig))

# ---------- EXPAND MULTIPLE MEMBERSHIP ----------
df_long_sig <- df %>%
  pivot_longer(
    cols = starts_with("sig_"),
    names_to = "comparison",
    values_to = "is_sig"
  ) %>%
  filter(is_sig) %>%
  mutate(
    comparison = recode(
      comparison,
      sig_D2_D0 = "D2-D0",
      sig_D7_D2 = "D7-D2",
      sig_D7_D0 = "D7-D0"
    )
  )

# Add back non-significant rows (optional: keep them)
df_nonsig <- df %>%
  filter(!(sig_D2_D0 | sig_D7_D2 | sig_D7_D0)) %>%
  mutate(comparison = "not significant")

df_expanded <- bind_rows(df_long_sig, df_nonsig)

# ---------- TREND BINS ----------
df_expanded <- df_expanded %>%
  mutate(
    trend_bin = case_when(
      D2 > eps & D7 > D2 + eps ~
        "D2 positive; D7 increases further",

      D2 > eps & D7 <= D2 + eps & D7 >= -eps ~
        "D2 positive; D7 decreases but stays non-negative",

      D2 > eps & D7 < -eps ~
        "D2 positive; D7 decreases below zero",

      abs(D2) <= eps & D7 > eps ~
        "D2 unchanged; D7 positive",

      abs(D2) <= eps & D7 < -eps ~
        "D2 unchanged; D7 negative",

      abs(D2) <= eps & abs(D7) <= eps ~
        "Flat / unchanged",

      D2 < -eps & D7 < D2 - eps ~
        "D2 negative; D7 decreases further",

      D2 < -eps & D7 >= D2 - eps & D7 < -eps ~
        "D2 negative; D7 recovers but stays negative",

      D2 < -eps & D7 >= -eps ~
        "D2 negative; D7 recovers to non-negative",

      TRUE ~ "Other"
    ),

    plot_bin = paste(trend_bin, comparison, sep = " __ ")
  )

# ---------- LONG FORMAT ----------
long_df <- df_expanded %>%
  select(profile_id, trend_bin, plot_bin, comparison, D0, D2, D7) %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

# ---------- SEGMENTS ----------
segments_df <- bind_rows(
  df_expanded %>%
    transmute(
      profile_id,
      plot_bin,
      comparison,
      x = 1, xend = 2,
      y = D0, yend = D2
    ),
  df_expanded %>%
    transmute(
      profile_id,
      plot_bin,
      comparison,
      x = 2, xend = 3,
      y = D2, yend = D7
    )
)

# ---------- GRAY BACKGROUND ----------
shade_df <- df_expanded %>%
  distinct(plot_bin, comparison) %>%
  mutate(
    xmin = case_when(
      comparison == "D2-D0" ~ 2,
      comparison == "D7-D2" ~ 1,
      comparison == "D7-D0" ~ NA_real_,
      comparison == "not significant" ~ 1
    ),
    xmax = case_when(
      comparison == "D2-D0" ~ 3,
      comparison == "D7-D2" ~ 2,
      comparison == "D7-D0" ~ NA_real_,
      comparison == "not significant" ~ 3
    )
  ) %>%
  filter(!is.na(xmin))

# ---------- LABEL CLEANUP ----------
facet_labels <- df_expanded %>%
  distinct(plot_bin, trend_bin) %>%
  deframe()

# ---------- PLOT ----------
p <- ggplot() +

  geom_rect(
    data = shade_df,
    aes(xmin = xmin, xmax = xmax, ymin = -Inf, ymax = Inf),
    fill = "grey90",
    alpha = 0.7
  ) +

  geom_segment(
    data = segments_df,
    aes(
      x = x, xend = xend,
      y = y, yend = yend,
      group = interaction(profile_id, comparison),
      color = comparison
    ),
    linewidth = 0.8,
    alpha = 0.85
  ) +

  geom_point(
    data = long_df,
    aes(
      x = x,
      y = value,
      group = interaction(profile_id, comparison),
      color = comparison
    ),
    size = 0.8,
    alpha = 0.85
  ) +

  facet_wrap(
    ~ plot_bin,
    labeller = labeller(plot_bin = facet_labels)
  ) +

  scale_x_continuous(
    breaks = 1:3,
    labels = c("D0", "D2", "D7")
  ) +

  scale_color_manual(
    name = "Comparisons",
    values = c(
      "D2-D0" = "#9adbcf",
      "D7-D2" = "#a7c7e7",
      "D7-D0" = "#c3b1e1",
      "not significant" = "grey65"
    )
  ) +

  theme_bw(base_size = 12) +
  theme(
    panel.grid.minor = element_blank(),
    strip.text = element_text(size = 8),
    plot.title = element_blank()
  ) +

  labs(
    x = NULL,
    y = "Log2-CPM"
  )

# ---------- OUTPUT ----------
ggsave("paneled_trend_plot.pdf", p, width = 16, height = 11)
ggsave("paneled_trend_plot.png", p, width = 16, height = 11, dpi = 300)

write_tsv(df_expanded, "binned_profiles.tsv")
write_tsv(segments_df, "binned_segments.tsv")


