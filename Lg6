#!/usr/bin/env Rscript

library(tidyverse)

infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

# ---------- PARSE SIGNIFICANCE ----------
# Sig order:
# 1 = D0-D7
# 2 = D2-D7
# 3 = D0-D2
#
# Examples:
# 0;1;1 = D2-D7 sig
# 1;0;1 = D0-D7 sig, full line dark
# 1;1;0 = D0-D2 sig

parse_sig <- function(x) {
  vals <- as.integer(str_split(as.character(x), ";", simplify = FALSE)[[1]])
  vals <- vals[!is.na(vals)]

  if (length(vals) < 3) {
    vals <- c(vals, rep(0, 3 - length(vals)))
  }

  usable <- floor(length(vals) / 3) * 3
  vals <- vals[seq_len(usable)]

  mat <- matrix(vals, ncol = 3, byrow = TRUE)

  sig_D0_D7 <- any(mat[, 1] == 1)
  sig_D2_D7 <- any(mat[, 2] == 1)
  sig_D0_D2 <- any(mat[, 3] == 1)

  tibble(
    sig_D0_D7 = sig_D0_D7,
    sig_D2_D7 = sig_D2_D7,
    sig_D0_D2 = sig_D0_D2,
    sig_pattern = paste(
      as.integer(sig_D0_D7),
      as.integer(sig_D2_D7),
      as.integer(sig_D0_D2),
      sep = ";"
    )
  )
}

# ---------- LOAD DATA ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    profile_id = row_number(),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7)
  ) %>%
  bind_cols(map_dfr(.$Sig, parse_sig))

# ---------- TREND BINS ----------
df <- df %>%
  mutate(
    bin = case_when(
      D2 > eps & D7 > D2 + eps ~
        "D2 positive; D7 increases further",

      D2 > eps & D7 <= D2 + eps & D7 >= -eps ~
        "D2 positive; D7 decreases but stays non-negative",

      D2 > eps & D7 < -eps ~
        "D2 positive; D7 decreases below zero",

      abs(D2) <= eps & D7 > eps ~
        "D2 unchanged; D7 positive",

      abs(D2) <= eps & D7 < -eps ~
        "D2 unchanged; D7 negative",

      abs(D2) <= eps & abs(D7) <= eps ~
        "Flat / unchanged",

      D2 < -eps & D7 < D2 - eps ~
        "D2 negative; D7 decreases further",

      D2 < -eps & D7 >= D2 - eps & D7 < -eps ~
        "D2 negative; D7 recovers but stays negative",

      D2 < -eps & D7 >= -eps ~
        "D2 negative; D7 recovers to non-negative",

      TRUE ~ "Other"
    )
  )

# ---------- SIGNIFICANCE BINS ----------
df <- df %>%
  mutate(
    sig_bin = case_when(
      sig_pattern == "0;0;0" ~ "no sig",
      sig_pattern == "0;1;1" ~ "D2-D7 sig",
      sig_pattern == "1;0;1" ~ "D0-D7 sig full line",
      sig_pattern == "1;1;0" ~ "D0-D2 sig",
      sig_pattern == "1;1;1" ~ "all sig",
      sig_pattern == "1;0;0" ~ "D0-D7 only",
      sig_pattern == "0;1;0" ~ "D2-D7 only",
      sig_pattern == "0;0;1" ~ "D0-D2 only",
      TRUE ~ sig_pattern
    ),
    plot_bin = paste(bin, sig_bin, sep = " | ")
  )

# ---------- LONG FORMAT ----------
long_df <- df %>%
  select(profile_id, plot_bin, D0, D2, D7) %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

# ---------- LINE SEGMENTS ----------
segments_df <- bind_rows(
  df %>%
    transmute(
      profile_id,
      plot_bin,
      segment = "D0-D2",
      x = 1,
      xend = 2,
      y = D0,
      yend = D2,
      sig = sig_D0_D2 | sig_D0_D7
    ),
  df %>%
    transmute(
      profile_id,
      plot_bin,
      segment = "D2-D7",
      x = 2,
      xend = 3,
      y = D2,
      yend = D7,
      sig = sig_D2_D7 | sig_D0_D7
    )
) %>%
  mutate(
    direction = case_when(
      yend > y + eps ~ "up",
      yend < y - eps ~ "down",
      TRUE ~ "flat"
    ),
    midpoint = (y + yend) / 2
  )

# ---------- BACKGROUND GRADIENT ----------
# Gradient is created per panel from low to high y-values.
background_df <- long_df %>%
  group_by(plot_bin) %>%
  summarise(
    ymin = min(value, na.rm = TRUE),
    ymax = max(value, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    ymin = if_else(ymin == ymax, ymin - 1, ymin),
    ymax = if_else(ymin == ymax, ymax + 1, ymax)
  ) %>%
  rowwise() %>%
  mutate(
    y = list(seq(ymin, ymax, length.out = 120)),
    x = list(seq(1, 3, length.out = 40))
  ) %>%
  unnest(y) %>%
  unnest(x) %>%
  mutate(fill_value = y)

# ---------- PLOT ----------
p <- ggplot() +

  # background gradient
  geom_tile(
    data = background_df,
    aes(x = x, y = y, fill = fill_value),
    alpha = 0.22,
    width = 0.08,
    height = Inf
  ) +

  # all segments faint
  geom_segment(
    data = segments_df,
    aes(
      x = x,
      xend = xend,
      y = y,
      yend = yend,
      group = profile_id
    ),
    color = "grey65",
    linewidth = 0.35,
    alpha = 0.35
  ) +

  # significant segments darker, drawn on top
  geom_segment(
    data = segments_df %>% filter(sig),
    aes(
      x = x,
      xend = xend,
      y = y,
      yend = yend,
      group = profile_id
    ),
    color = "black",
    linewidth = 1.05,
    alpha = 0.95
  ) +

  # points
  geom_point(
    data = long_df,
    aes(x = x, y = value, group = profile_id),
    size = 0.65,
    alpha = 0.45,
    color = "black"
  ) +

  facet_wrap(~ plot_bin, scales = "free_y") +

  scale_x_continuous(
    breaks = 1:3,
    labels = c("D0", "D2", "D7")
  ) +

  scale_fill_gradient2(
    low = "blue",
    mid = "white",
    high = "red",
    midpoint = 0,
    guide = "none"
  ) +

  theme_bw(base_size = 12) +
  theme(
    panel.grid.minor = element_blank(),
    strip.text = element_text(size = 8),
    panel.background = element_rect(fill = NA),
    plot.title = element_text(face = "bold")
  ) +

  labs(
    x = NULL,
    y = "Value",
    title = "Paneled Line Plot by Trend and Significance",
    subtitle = "Grey = non-significant; black = significant segment; background shows value gradient"
  )

# ---------- OUTPUT ----------
ggsave("paneled_trend_plot.pdf", p, width = 16, height = 11)
ggsave("paneled_trend_plot.png", p, width = 16, height = 11, dpi = 300)

write_tsv(df, "binned_profiles.tsv")
write_tsv(segments_df, "binned_segments.tsv")


