#!/usr/bin/env Rscript

library(tidyverse)

infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

# ---------- PARSE SIGNIFICANCE ----------
# Sig mapping:
# 1;1;0 = D2-D0
# 0;1;1 = D7-D2
# 1;0;1 = D7-D0

parse_sig <- function(x) {
  vals <- as.integer(str_split(as.character(x), ";", simplify = FALSE)[[1]])
  vals <- vals[!is.na(vals)]

  if (length(vals) < 3) vals <- c(vals, rep(0, 3 - length(vals)))

  usable <- floor(length(vals) / 3) * 3
  vals <- vals[seq_len(usable)]

  mat <- matrix(vals, ncol = 3, byrow = TRUE)

  sig_D2_D0 <- any(mat[, 1] == 1 & mat[, 2] == 1 & mat[, 3] == 0)
  sig_D7_D2 <- any(mat[, 1] == 0 & mat[, 2] == 1 & mat[, 3] == 1)
  sig_D7_D0 <- any(mat[, 1] == 1 & mat[, 2] == 0 & mat[, 3] == 1)

  tibble(
    sig_D2_D0 = sig_D2_D0,
    sig_D7_D2 = sig_D7_D2,
    sig_D7_D0 = sig_D7_D0,
    comparison = case_when(
      sig_D2_D0 & !sig_D7_D2 & !sig_D7_D0 ~ "D2-D0",
      sig_D7_D2 & !sig_D2_D0 & !sig_D7_D0 ~ "D7-D2",
      sig_D7_D0 & !sig_D2_D0 & !sig_D7_D2 ~ "D7-D0",
      sig_D2_D0 | sig_D7_D2 | sig_D7_D0 ~ "multiple",
      TRUE ~ "not significant"
    )
  )
}

# ---------- LOAD DATA ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    profile_id = row_number(),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7)
  ) %>%
  bind_cols(map_dfr(.$Sig, parse_sig))

# ---------- TREND BINS ----------
df <- df %>%
  mutate(
    trend_bin = case_when(
      D2 > eps & D7 > D2 + eps ~
        "D2 positive; D7 increases further",

      D2 > eps & D7 <= D2 + eps & D7 >= -eps ~
        "D2 positive; D7 decreases but stays non-negative",

      D2 > eps & D7 < -eps ~
        "D2 positive; D7 decreases below zero",

      abs(D2) <= eps & D7 > eps ~
        "D2 unchanged; D7 positive",

      abs(D2) <= eps & D7 < -eps ~
        "D2 unchanged; D7 negative",

      abs(D2) <= eps & abs(D7) <= eps ~
        "Flat / unchanged",

      D2 < -eps & D7 < D2 - eps ~
        "D2 negative; D7 decreases further",

      D2 < -eps & D7 >= D2 - eps & D7 < -eps ~
        "D2 negative; D7 recovers but stays negative",

      D2 < -eps & D7 >= -eps ~
        "D2 negative; D7 recovers to non-negative",

      TRUE ~ "Other"
    )
  )

# ---------- LONG FORMAT ----------
long_df <- df %>%
  select(profile_id, trend_bin, comparison, D0, D2, D7) %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

# ---------- LINE SEGMENTS ----------
segments_df <- bind_rows(
  df %>%
    transmute(
      profile_id,
      trend_bin,
      comparison,
      x = 1,
      xend = 2,
      y = D0,
      yend = D2
    ),
  df %>%
    transmute(
      profile_id,
      trend_bin,
      comparison,
      x = 2,
      xend = 3,
      y = D2,
      yend = D7
    )
)

# ---------- PLOT ----------
p <- ggplot() +

  # Non-significant lines first, in light gray
  geom_segment(
    data = segments_df %>% filter(comparison == "not significant"),
    aes(
      x = x,
      xend = xend,
      y = y,
      yend = yend,
      group = profile_id
    ),
    color = "grey85",
    linewidth = 0.7,
    alpha = 0.8
  ) +

  geom_point(
    data = long_df %>% filter(comparison == "not significant"),
    aes(x = x, y = value, group = profile_id),
    color = "grey85",
    size = 0.7,
    alpha = 0.8
  ) +

  # Significant lines on top, colored by comparison
  geom_segment(
    data = segments_df %>% filter(comparison != "not significant"),
    aes(
      x = x,
      xend = xend,
      y = y,
      yend = yend,
      group = profile_id,
      color = comparison
    ),
    linewidth = 0.8,
    alpha = 0.85
  ) +

  geom_point(
    data = long_df %>% filter(comparison != "not significant"),
    aes(
      x = x,
      y = value,
      group = profile_id,
      color = comparison
    ),
    size = 0.8,
    alpha = 0.85
  ) +

  facet_wrap(~ trend_bin) +

  scale_x_continuous(
    breaks = 1:3,
    labels = c("D0", "D2", "D7")
  ) +

  scale_color_manual(
    name = "Comparisons",
    values = c(
      "D2-D0" = "#8dd3c7",
      "D7-D2" = "#fdb462",
      "D7-D0" = "#bebada",
      "multiple" = "#fb8072"
    )
  ) +

  theme_bw(base_size = 12) +
  theme(
    panel.grid.minor = element_blank(),
    strip.text = element_text(size = 8),
    plot.title = element_blank()
  ) +

  labs(
    x = NULL,
    y = "Log2-CPM"
  )

# ---------- OUTPUT ----------
ggsave("paneled_trend_plot.pdf", p, width = 16, height = 11)
ggsave("paneled_trend_plot.png", p, width = 16, height = 11, dpi = 300)

write_tsv(df, "binned_profiles.tsv")
write_tsv(segments_df, "binned_segments.tsv")
