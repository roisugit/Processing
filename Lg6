#!/usr/bin/env Rscript

library(tidyverse)

infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

parse_sig <- function(x) {
  vals <- as.integer(str_split(as.character(x), ";", simplify = FALSE)[[1]])
  vals <- vals[!is.na(vals)]

  if (length(vals) < 3) vals <- c(vals, rep(0, 3 - length(vals)))

  usable <- floor(length(vals) / 3) * 3
  vals <- vals[seq_len(usable)]

  mat <- matrix(vals, ncol = 3, byrow = TRUE)

  tibble(
    sig_D2_D0 = any(mat[, 1] == 1),
    sig_D7_D2 = any(mat[, 2] == 1),
    sig_D7_D0 = any(mat[, 3] == 1)
  )
}

df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    profile_id = row_number(),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7)
  ) %>%
  bind_cols(map_dfr(.$Sig, parse_sig)) %>%
  mutate(
    d_D2_D0 = D2 - D0,
    d_D7_D2 = D7 - D2,

    trend_bin = case_when(
      d_D2_D0 > eps  & d_D7_D2 > eps  ~ "Increase, increase",
      d_D2_D0 < -eps & d_D7_D2 < -eps ~ "Decrease, decrease",
      d_D2_D0 > eps  & d_D7_D2 < -eps ~ "Increase, decrease",
      d_D2_D0 < -eps & d_D7_D2 > eps  ~ "Decrease, increase",
      TRUE ~ NA_character_
    ),

    comparison_bin = case_when(
      sig_D2_D0 & !sig_D7_D2 & !sig_D7_D0 ~
        "D2-D0",

      !sig_D2_D0 & sig_D7_D2 & !sig_D7_D0 ~
        "D7-D2",

      !sig_D2_D0 & !sig_D7_D2 & sig_D7_D0 ~
        "D7-D0",

      !sig_D2_D0 & sig_D7_D2 & sig_D7_D0 ~
        "D7-D2 + D7-D0",

      sig_D2_D0 & !sig_D7_D2 & sig_D7_D0 ~
        "D2-D0 + D7-D0",

      TRUE ~ NA_character_
    )
  )

df_unplotted <- df %>%
  filter(is.na(trend_bin) | is.na(comparison_bin))

df_binned <- df %>%
  filter(!is.na(trend_bin), !is.na(comparison_bin)) %>%
  mutate(
    trend_bin = factor(
      trend_bin,
      levels = c(
        "Increase, increase",
        "Decrease, decrease",
        "Increase, decrease",
        "Decrease, increase"
      )
    ),
    comparison_bin = factor(
      comparison_bin,
      levels = c(
        "D2-D0",
        "D7-D2",
        "D7-D0",
        "D7-D2 + D7-D0",
        "D2-D0 + D7-D0"
      )
    )
  )

long_df <- df_binned %>%
  select(profile_id, trend_bin, comparison_bin, D0, D2, D7) %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

segments_df <- bind_rows(
  df_binned %>%
    transmute(
      profile_id, trend_bin, comparison_bin,
      x = 1, xend = 2,
      y = D0, yend = D2
    ),
  df_binned %>%
    transmute(
      profile_id, trend_bin, comparison_bin,
      x = 2, xend = 3,
      y = D2, yend = D7
    )
)

panel_ranges <- long_df %>%
  group_by(trend_bin, comparison_bin) %>%
  summarise(
    ymin = min(value, na.rm = TRUE),
    ymax = max(value, na.rm = TRUE),
    yrange = ymax - ymin,
    .groups = "drop"
  ) %>%
  mutate(
    yrange = if_else(yrange == 0, 1, yrange),
    bar_base = ymax + 0.08 * yrange,
    bar_step = 0.08 * yrange
  )

sig_bars <- df_binned %>%
  distinct(trend_bin, comparison_bin) %>%
  left_join(panel_ranges, by = c("trend_bin", "comparison_bin")) %>%
  rowwise() %>%
  do({
    row <- .

    bars <- switch(
      as.character(row$comparison_bin),

      "D2-D0" = tibble(x = 1, xend = 2, level = 0),
