#!/usr/bin/env Rscript

library(tidyverse)

# ---------- INPUT ----------
infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

# ---------- PARSE SIGNIFICANCE ----------
parse_sig <- function(x) {
  vals <- as.integer(str_split(as.character(x), ";", simplify = FALSE)[[1]])
  vals <- vals[!is.na(vals)]

  if (length(vals) < 3) {
    vals <- c(vals, rep(0, 3 - length(vals)))
  }

  usable <- floor(length(vals) / 3) * 3
  vals <- vals[seq_len(usable)]

  mat <- matrix(vals, ncol = 3, byrow = TRUE)

  sig_D2_D0 <- any(mat[, 1] == 1 & mat[, 2] == 1 & mat[, 3] == 0)
  sig_D7_D2 <- any(mat[, 1] == 0 & mat[, 2] == 1 & mat[, 3] == 1)
  sig_D7_D0 <- any(mat[, 1] == 1 & mat[, 2] == 0 & mat[, 3] == 1)

  tibble(
    sig_D2_D0 = sig_D2_D0,
    sig_D7_D2 = sig_D7_D2,
    sig_D7_D0 = sig_D7_D0,
    sig_group = case_when(
      sig_D2_D0 & !sig_D7_D2 & !sig_D7_D0 ~ "D2-D0",
      sig_D7_D2 & !sig_D2_D0 & !sig_D7_D0 ~ "D7-D2",
      sig_D7_D0 & !sig_D2_D0 & !sig_D7_D2 ~ "D7-D0",
      sig_D2_D0 | sig_D7_D2 | sig_D7_D0 ~ "multiple sig",
      TRUE ~ "not significant"
    )
  )
}

# ---------- LOAD DATA ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    profile_id = row_number(),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7)
  ) %>%
  bind_cols(map_dfr(.$Sig, parse_sig))

# ---------- TREND BINS ----------
df <- df %>%
  mutate(
    trend_bin = case_when(
      D2 > eps & D7 > D2 + eps ~
        "D2 positive; D7 increases further",

      D2 > eps & D7 <= D2 + eps & D7 >= -eps ~
        "D2 positive; D7 decreases but stays non-negative",

      D2 > eps & D7 < -eps ~
        "D2 positive; D7 decreases below zero",

      abs(D2) <= eps & D7 > eps ~
        "D2 unchanged; D7 positive",

      abs(D2) <= eps & D7 < -eps ~
        "D2 unchanged; D7 negative",

      abs(D2) <= eps & abs(D7) <= eps ~
        "Flat / unchanged",

      D2 < -eps & D7 < D2 - eps ~
        "D2 negative; D7 decreases further",

      D2 < -eps & D7 >= D2 - eps & D7 < -eps ~
        "D2 negative; D7 recovers but stays negative",

      D2 < -eps & D7 >= -eps ~
        "D2 negative; D7 recovers to non-negative",

      TRUE ~ "Other"
    ),
    plot_bin = paste(trend_bin, sig_group, sep = " | ")
  )

# ---------- LONG FORMAT ----------
long_df <- df %>%
  select(profile_id, plot_bin, sig_group, D0, D2, D7) %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

# ---------- LINE SEGMENTS ----------
segments_df <- bind_rows(
  df %>%
    transmute(
      profile_id,
      plot_bin,
      sig_group,
      segment = "D0-D2",
      x = 1,
      xend = 2,
      y = D0,
      yend = D2
    ),
  df %>%
    transmute(
      profile_id,
      plot_bin,
      sig_group,
      segment = "D2-D7",
      x = 2,
      xend = 3,
      y = D2,
      yend = D7
    )
)

# ---------- PLOT ----------
p <- ggplot() +
  geom_segment(
    data = segments_df,
    aes(
      x = x,
      xend = xend,
      y = y,
      yend = yend,
      group = profile_id,
      color = sig_group
    ),
    linewidth = 0.8,
    alpha = 0.75
  ) +
  geom_point(
    data = long_df,
    aes(
      x = x,
      y = value,
      group = profile_id,
      color = sig_group
    ),
    size = 0.8,
    alpha = 0.8
  ) +
  facet_wrap(~ plot_bin, scales = "free_y") +
  scale_x_continuous(
    breaks = 1:3,
    labels = c("D0", "D2", "D7")
  ) +
  scale_color_manual(
    values = c(
      "D2-D0" = "#1b9e77",
      "D7-D2" = "#d95f02",
      "D7-D0" = "#7570b3",
      "multiple sig" = "#e7298a",
      "not significant" = "grey70"
    )
  ) +
  theme_bw(base_size = 12) +
  theme(
    panel.grid.minor = element_blank(),
    strip.text = element_text(size = 8),
    plot.title = element_text(face = "bold")
  ) +
  labs(
    x = NULL,
    y = "Value",
    color = "Significance group",
    title = "Paneled Line Plot by Trend and Significance Group"
  )

# ---------- OUTPUT ----------
ggsave("paneled_trend_plot.pdf", p, width = 16, height = 11)
ggsave("paneled_trend_plot.png", p, width = 16, height = 11, dpi = 300)

write_tsv(df, "binned_profiles.tsv")
write_tsv(segments_df, "binned_segments.tsv")
