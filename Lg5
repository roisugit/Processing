#!/usr/bin/env Rscript

library(tidyverse)

# ---------- INPUT ----------
infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

# ---------- PARSE SIGNIFICANCE ----------
# Expected triplet order:
# 1 = D0-D7
# 2 = D2-D7
# 3 = D0-D2
parse_sig <- function(x) {
  vals <- as.integer(str_split(as.character(x), ";", simplify = FALSE)[[1]])
  vals <- vals[!is.na(vals)]

  if (length(vals) < 3) vals <- c(vals, rep(0, 3 - length(vals)))

  mat <- matrix(vals[seq_len(floor(length(vals) / 3) * 3)], ncol = 3, byrow = TRUE)

  sig_D0_D7 <- any(mat[, 1] == 1)
  sig_D2_D7 <- any(mat[, 2] == 1)
  sig_D0_D2 <- any(mat[, 3] == 1)

  tibble(
    sig_D0_D7 = sig_D0_D7,
    sig_D2_D7 = sig_D2_D7,
    sig_D0_D2 = sig_D0_D2,
    sig_pattern = paste(
      as.integer(sig_D0_D7),
      as.integer(sig_D2_D7),
      as.integer(sig_D0_D2),
      sep = ";"
    )
  )
}

# ---------- LOAD DATA ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    profile_id = row_number(),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7)
  ) %>%
  bind_cols(map_dfr(.$Sig, parse_sig))

# ---------- TREND BINS ----------
df <- df %>%
  mutate(
    bin = case_when(
      D2 > eps  & D7 > D2 + eps ~ "D2 positive; D7 increases further",
      D2 > eps  & D7 <= D2 + eps & D7 >= -eps ~ "D2 positive; D7 decreases but stays non-negative",
      D2 > eps  & D7 < -eps ~ "D2 positive; D7 decreases below zero",

      abs(D2) <= eps & D7 > eps ~ "D2 unchanged; D7 positive",
      abs(D2) <= eps & D7 < -eps ~ "D2 unchanged; D7 negative",
      abs(D2) <= eps & abs(D7) <= eps ~ "Flat / unchanged",

      D2 < -eps & D7 < D2 - eps ~ "D2 negative; D7 decreases further",
      D2 < -eps & D7 >= D2 - eps & D7 < -eps ~ "D2 negative; D7 recovers but stays negative",
      D2 < -eps & D7 >= -eps ~ "D2 negative; D7 recovers to non-negative",

      TRUE ~ "Other"
    )
  )

# ---------- SIGNIFICANCE BINS ----------
df <- df %>%
  mutate(
    sig_bin = case_when(
      sig_pattern == "0;0;0" ~ "no sig",
      sig_pattern == "0;1;1" ~ "D2-D7 sig",
      sig_pattern == "1;0;1" ~ "D0-D7 sig (full line)",
      sig_pattern == "1;1;0" ~ "D0-D2 sig",
      sig_pattern == "1;1;1" ~ "all sig",
      sig_pattern == "1;0;0" ~ "D0-D7 only",
      sig_pattern == "0;1;0" ~ "D2-D7 only",
      sig_pattern == "0;0;1" ~ "D0-D2 only",
      TRUE ~ sig_pattern
    ),
    plot_bin = paste(bin, sig_bin, sep = " | ")
  )

# ---------- LONG FORMAT ----------
long_df <- df %>%
  select(profile_id, plot_bin, D0, D2, D7) %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

# ---------- SEGMENTS ----------
segments_df <- df %>%
  transmute(
    profile_id,
    plot_bin,
    x = 1,
    xend = 2,
    y = D0,
    yend = D2,
    sig = sig_D0_D2 | sig_D0_D7   # first segment
  ) %>%
  bind_rows(
    df %>%
      transmute(
        profile_id,
        plot_bin,
        x = 2,
        xend = 3,
        y = D2,
        yend = D7,
        sig = sig_D2_D7 | sig_D0_D7  # second segment
      )
  )

# ---------- PLOT ----------
p <- ggplot() +
  geom_segment(
    data = segments_df,
    aes(x = x, xend = xend, y = y, yend = yend,
        group = profile_id,
        alpha = sig,
        linewidth = sig)
  ) +
  geom_point(
    data = long_df,
    aes(x = x, y = value, group = profile_id),
    size = 0.7,
    alpha = 0.4
  ) +
  facet_wrap(~ plot_bin, scales = "free_y") +
  scale_x_continuous(
    breaks = 1:3,
    labels = c("D0", "D2", "D7")
  ) +
  scale_alpha_manual(values = c(`FALSE` = 0.15, `TRUE` = 0.95), guide = "none") +
  scale_linewidth_manual(values = c(`FALSE` = 0.25, `TRUE` = 1.0), guide = "none") +
  theme_bw(base_size = 12) +
  labs(
    x = NULL,
    y = "Value",
    title = "Paneled Line Plot by Trend + Significance",
    subtitle = "Dark segments indicate significant comparisons"
  )

# ---------- OUTPUT ----------
ggsave("paneled_trend_plot.pdf", p, width = 14, height = 10)
ggsave("paneled_trend_plot.png", p, width = 14, height = 10, dpi = 300)

write_tsv(df, "binned_profiles.tsv")


