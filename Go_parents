import pandas as pd
import requests
from collections import defaultdict
from functools import lru_cache

INPUT_CSV = "input.csv"
OUTPUT_CSV = "go_levels_lookup.csv"
GO_COLUMN = "GO_ID"

OBO_URL = "http://purl.obolibrary.org/obo/go/go-basic.obo"
OBO_FILE = "go-basic.obo"

INCLUDE_PART_OF = True


def download_obo():
    print("Downloading GO ontology...")
    r = requests.get(OBO_URL)
    r.raise_for_status()
    with open(OBO_FILE, "w", encoding="utf-8") as f:
        f.write(r.text)


def parse_obo():
    terms = {}
    current = None

    with open(OBO_FILE, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()

            if line == "[Term]":
                current = {
                    "id": None,
                    "name": None,
                    "namespace": None,
                    "parents": []
                }

            elif line == "":
                if current and current["id"]:
                    terms[current["id"]] = current
                current = None

            elif current is not None:
                if line.startswith("id: GO:"):
                    current["id"] = line.replace("id: ", "")

                elif line.startswith("name: "):
                    current["name"] = line.replace("name: ", "")

                elif line.startswith("namespace: "):
                    current["namespace"] = line.replace("namespace: ", "")

                elif line.startswith("is_a: "):
                    parent = line.split()[1]
                    current["parents"].append(parent)

                elif INCLUDE_PART_OF and line.startswith("relationship: part_of "):
                    parent = line.split()[2]
                    current["parents"].append(parent)

    return terms


@lru_cache(None)
def get_paths_to_root(go_id):
    term = TERMS.get(go_id)

    if term is None:
        return []

    parents = term["parents"]

    if not parents:
        return [[go_id]]

    paths = []

    for parent in parents:
        parent_paths = get_paths_to_root(parent)

        for path in parent_paths:
            paths.append(path + [go_id])

    return paths


def extract_levels(go_id):
    if go_id not in TERMS:
        return {
            "input_GO": go_id,
            "lookup_status": "not_found"
        }

    paths = get_paths_to_root(go_id)

    levels = defaultdict(list)

    for path in paths:
        for i, term_id in enumerate(path):
            level = i + 1
            term = TERMS[term_id]
            label = f"{term_id} | {term['name']}"

            if label not in levels[level]:
                levels[level].append(label)

    row = {
        "input_GO": go_id,
        "input_GO_name": TERMS[go_id]["name"],
        "namespace": TERMS[go_id]["namespace"],
        "lookup_status": "found"
    }

    for level in sorted(levels):
        row[f"GO_level_{level}"] = "; ".join(sorted(levels[level]))

    return row


def main():
    download_obo()

    global TERMS
    TERMS = parse_obo()

    df = pd.read_csv(INPUT_CSV)

    go_ids = (
        df[GO_COLUMN]
        .dropna()
        .astype(str)
        .str.strip()
        .drop_duplicates()
        .tolist()
    )

    rows = []

    for go_id in go_ids:
        print(f"Processing {go_id}")
        rows.append(extract_levels(go_id))

    out = pd.DataFrame(rows)
    out.to_csv(OUTPUT_CSV, index=False)

    print(f"Saved: {OUTPUT_CSV}")


if __name__ == "__main__":
    main()
