import pandas as pd
import requests
import time
from collections import defaultdict

INPUT_CSV = "input.csv"
OUTPUT_CSV = "go_levels_lookup.csv"
GO_COLUMN = "GO_ID"

BASE = "https://www.ebi.ac.uk/QuickGO/services/ontology/go/terms"


def get_json(url):
    r = requests.get(url, headers={"Accept": "application/json"})
    r.raise_for_status()
    return r.json()


def get_term(go_id):
    url = f"{BASE}/{go_id}/complete"
    data = get_json(url)

    results = data.get("results", [])
    if not results:
        return None

    return results[0]


def collect_ancestors(term):
    levels = defaultdict(list)

    def add_term(t):
        go_id = t.get("id")
        name = t.get("name")
        depth = t.get("depth")

        if go_id and name and depth is not None:
            level = depth + 1
            label = f"{go_id} | {name}"
            if label not in levels[level]:
                levels[level].append(label)

    add_term(term)

    for ancestor in term.get("ancestors", []):
        add_term(ancestor)

    return levels


def extract_levels(go_id):
    term = get_term(go_id)

    if term is None:
        return {
            "input_GO": go_id,
            "lookup_status": "not_found"
        }

    levels = collect_ancestors(term)

    row = {
        "input_GO": go_id,
        "input_GO_name": term.get("name"),
        "ontology": term.get("aspect"),
        "lookup_status": "found"
    }

    for level in sorted(levels.keys()):
        row[f"GO_level_{level}"] = "; ".join(sorted(levels[level]))

    return row


def main():
    df = pd.read_csv(INPUT_CSV)

    go_ids = (
        df[GO_COLUMN]
        .dropna()
        .astype(str)
        .str.strip()
        .drop_duplicates()
        .tolist()
    )

    rows = []

    for i, go_id in enumerate(go_ids):
        print(f"[{i+1}/{len(go_ids)}] {go_id}")

        try:
            rows.append(extract_levels(go_id))
        except Exception as e:
            rows.append({
                "input_GO": go_id,
                "lookup_status": "error",
                "error_message": str(e)
            })

        time.sleep(0.1)

    out = pd.DataFrame(rows)
    out.to_csv(OUTPUT_CSV, index=False)

    print(f"Saved new GO lookup CSV: {OUTPUT_CSV}")


if __name__ == "__main__":
    main()
