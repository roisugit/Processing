$termsFile = "C:\path\to\terms.txt"
$csvFile   = "C:\path\to\input.csv"
$outFile   = "C:\path\to\matches.csv"

# Read and clean terms
$terms = Get-Content $termsFile |
    ForEach-Object { $_.Trim() } |
    Where-Object { $_ -ne "" }

# Import CSV
$rows = Import-Csv $csvFile

# Collect matching rows
$matches = foreach ($row in $rows) {
    $found = $false

    foreach ($term in $terms) {
        foreach ($prop in $row.PSObject.Properties) {
            $value = [string]$prop.Value

            if ($value -match [regex]::Escape($term)) {
                $found = $true
                break
            }
        }

        if ($found) { break }
    }

    if ($found) { $row }
}

$matches | Export-Csv $outFile -NoTypeInformation
Write-Host "Done. Matches written to $outFile"
