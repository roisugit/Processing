#!/usr/bin/env Rscript

library(tidyverse)

infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

trend_levels <- c(
  "D7 increases from D2",
  "D7 decreases from D2"
)

comparison_levels <- c(
  "D2-D0",
  "D7-D2",
  "D7-D0",
  "D2-D0 + D7-D2",
  "D2-D0 + D7-D0",
  "D7-D2 + D7-D0"
)

plot_comparisons <- c(
  "D2-D0",
  "D7-D2",
  "D7-D0",
  "D2-D0 + D7-D2",
  "D7-D2 + D7-D0"
)

horizontal_levels <- c(
  paste("D7 increases from D2", plot_comparisons, sep = " | "),
  "BLANK",
  paste("D7 decreases from D2", plot_comparisons, sep = " | "),
  "D2-D0 + D7-D0"
)

vertical_levels <- c(
  as.vector(rbind(
    paste("D7 increases from D2", plot_comparisons, sep = " | "),
    paste("D7 decreases from D2", plot_comparisons, sep = " | ")
  )),
  "BLANK",
  "D2-D0 + D7-D0"
)

panel_colors <- c(
  "D7 increases from D2 | D2-D0" = "#1B9E77",
  "D7 increases from D2 | D7-D2" = "#377EB8",
  "D7 increases from D2 | D7-D0" = "#984EA3",
  "D7 increases from D2 | D2-D0 + D7-D2" = "#E41A1C",
  "D7 increases from D2 | D7-D2 + D7-D0" = "#4DAF4A",

  "D7 decreases from D2 | D2-D0" = "#A65628",
  "D7 decreases from D2 | D7-D2" = "#F781BF",
  "D7 decreases from D2 | D7-D0" = "#999999",
  "D7 decreases from D2 | D2-D0 + D7-D2" = "#66C2A5",
  "D7 decreases from D2 | D7-D2 + D7-D0" = "#8DA0CB",

  "D2-D0 + D7-D0" = "#FC8D62"
)

panel_labels <- c(
  setNames(plot_comparisons, paste("D7 increases from D2", plot_comparisons, sep = " | ")),
  setNames(plot_comparisons, paste("D7 decreases from D2", plot_comparisons, sep = " | ")),
  "D2-D0 + D7-D0" = "D2-D0 + D7-D0",
  "BLANK" = ""
)

# ---------- LOAD ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    Gene = as.character(Gene),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7),
    Combination = str_replace_all(as.character(Combination), "_", "-")
  )

# ---------- COLLAPSE BY GENE ----------
df_gene <- df %>%
  group_by(Gene) %>%
  summarise(
    D0 = first(D0),
    D2 = first(D2),
    D7 = first(D7),

    has_D2_D0 = any(Combination == "D2-D0"),
    has_D7_D2 = any(Combination == "D7-D2"),
    has_D7_D0 = any(Combination == "D7-D0"),

    .groups = "drop"
  ) %>%
  mutate(
    profile_id = row_number(),

    comparison_bin = case_when(
      has_D2_D0 & !has_D7_D2 & !has_D7_D0 ~ "D2-D0",
      !has_D2_D0 & has_D7_D2 & !has_D7_D0 ~ "D7-D2",
      !has_D2_D0 & !has_D7_D2 & has_D7_D0 ~ "D7-D0",
      has_D2_D0 & has_D7_D2 & !has_D7_D0 ~ "D2-D0 + D7-D2",
      has_D2_D0 & !has_D7_D2 & has_D7_D0 ~ "D2-D0 + D7-D0",
      !has_D2_D0 & has_D7_D2 & has_D7_D0 ~ "D7-D2 + D7-D0",
      TRUE ~ NA_character_
    ),

    d_D7_D2 = D7 - D2,

    trend_bin = case_when(
      d_D7_D2 > eps  ~ "D7 increases from D2",
      d_D7_D2 < -eps ~ "D7 decreases from D2",
      TRUE ~ NA_character_
    )
  )

# ---------- FILTER ----------
df_unplotted <- df_gene %>%
  filter(is.na(trend_bin) | is.na(comparison_bin))

df_binned <- df_gene %>%
  filter(!is.na(trend_bin), !is.na(comparison_bin)) %>%
  mutate(
    trend_bin = factor(trend_bin, levels = trend_levels),
    comparison_bin = factor(comparison_bin, levels = comparison_levels),

    panel_bin = if_else(
      comparison_bin == "D2-D0 + D7-D0",
      "D2-D0 + D7-D0",
      paste(trend_bin, comparison_bin, sep = " | ")
    )
  )

# ---------- LONG FORMAT ----------
long_df <- df_binned %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

# ---------- SEGMENTS ----------
segments_df <- bind_rows(
  df_binned %>% transmute(profile_id, panel_bin, comparison_bin, x = 1, xend = 2, y = D0, yend = D2),
  df_binned %>% transmute(profile_id, panel_bin, comparison_bin, x = 2, xend = 3, y = D2, yend = D7)
)

# ---------- SIGNIFICANCE STAPLES ----------
sig_bars <- df_binned %>%
  distinct(panel_bin, comparison_bin) %>%
  rowwise() %>%
  do({
    row <- .

    bars <- switch(
      as.character(row$comparison_bin),

      "D2-D0" = tibble(x = 1, xend = 2, level = 0),
      "D7-D2" = tibble(x = 2, xend = 3, level = 0),
      "D7-D0" = tibble(x = 1, xend = 3, level = 0),

      "D2-D0 + D7-D2" = tibble(x = c(1, 2), xend = c(2, 3), level = c(0, 1)),
      "D2-D0 + D7-D0" = tibble(x = c(1, 1), xend = c(2, 3), level = c(0, 1)),
      "D7-D2 + D7-D0" = tibble(x = c(2, 1), xend = c(3, 3), level = c(0, 1))
    )

    bars %>%
      mutate(
        panel_bin = row$panel_bin,
        comparison_bin = row$comparison_bin,
        y = Inf - (0.12 + 0.10 * level),
        tick = 0.05
      )
  }) %>%
  ungroup()

# ---------- PLOT FUNCTION ----------
make_plot <- function(panel_order, ncol) {
  plot_long_df <- long_df %>%
    mutate(panel_bin = factor(panel_bin, levels = panel_order))

  plot_segments_df <- segments_df %>%
    mutate(panel_bin = factor(panel_bin, levels = panel_order))

  plot_sig_bars <- sig_bars %>%
    mutate(panel_bin = factor(panel_bin, levels = panel_order))

  ggplot() +
    geom_segment(
      data = plot_segments_df,
      aes(x = x, xend = xend, y = y, yend = yend, group = profile_id, color = panel_bin),
      linewidth = 0.8,
      alpha = 0.85
    ) +
    geom_point(
      data = plot_long_df,
      aes(x = x, y = value, group = profile_id, color = panel_bin),
      size = 0.8,
      alpha = 0.85
    ) +

    geom_segment(data = plot_sig_bars, aes(x = x, xend = xend, y = y, yend = y), color = "black", linewidth = 0.6) +
    geom_segment(data = plot_sig_bars, aes(x = x, xend = x, y = y, yend = y - tick), color = "black", linewidth = 0.6) +
    geom_segment(data = plot_sig_bars, aes(x = xend, xend = xend, y = y, yend = y - tick), color = "black", linewidth = 0.6) +

    geom_text(
      data = plot_sig_bars,
      aes(x = (x + xend) / 2, y = y + 0.5 * tick),
      label = "*",
      size = 4
    ) +

    facet_wrap(
      ~ panel_bin,
      ncol = ncol,
      drop = FALSE,
      labeller = as_labeller(panel_labels)
    ) +

    scale_x_continuous(breaks = 1:3, labels = c("D0", "D2", "D7")) +
    scale_y_continuous(breaks = function(x) pretty(x, n = 3)) +
    scale_color_manual(values = panel_colors) +

    coord_cartesian(clip = "off") +

    theme_bw(base_size = 12) +
    theme(
      panel.grid.minor = element_blank(),
      strip.text = element_text(size = 8),
      legend.position = "none",
      plot.margin = margin(t = 20, r = 5, b = 5, l = 5)
    ) +
    labs(x = NULL, y = "Log2-CPM")
}

p_horizontal <- make_plot(horizontal_levels, ncol = 6)
p_vertical <- make_plot(vertical_levels, ncol = 2)

# ---------- OUTPUT ----------
ggsave("paneled_trend_plot_horizontal.pdf", p_horizontal, width = 22, height = 8)
ggsave("paneled_trend_plot_horizontal.png", p_horizontal, width = 22, height = 8, dpi = 300)

ggsave("paneled_trend_plot_vertical.pdf", p_vertical, width = 10, height = 24)
ggsave("paneled_trend_plot_vertical.png", p_vertical, width = 10, height = 24, dpi = 300)

write_tsv(df_gene, "gene_combination_profiles.tsv")
write_tsv(df_binned, "binned_profiles.tsv")
write_tsv(segments_df, "binned_segments.tsv")
write_tsv(df_unplotted, "unplotted_profiles.tsv")
