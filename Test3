options(stringsAsFactors = FALSE)

# =========================================================
# STRING GO BP BAR PLOTS + GENE TABLE OUTPUT
#
# - Reads UP_sig.csv and DOWN_sig.csv from comparison folders
# - Runs STRING enrichment for GO Biological Process
# - Uses preferredNames from get_enrichment() for gene membership
# - Plots bars only
# - Saves gene memberships for each bar as CSV
# - Builds 1-row faceted plot with panels side-by-side
# - DOWN panels are labeled "_inverse"
# - Publication labels can be customized at bottom
# =========================================================

if (!requireNamespace("BiocManager", quietly = TRUE)) {
  install.packages("BiocManager")
}
if (!requireNamespace("STRINGdb", quietly = TRUE)) {
  BiocManager::install("STRINGdb")
}

pkgs <- c("STRINGdb", "readr", "dplyr", "stringr", "ggplot2", "tibble")
to_install <- pkgs[!vapply(pkgs, requireNamespace, logical(1), quietly = TRUE)]
if (length(to_install) > 0) install.packages(to_install)

library(STRINGdb)
library(readr)
library(dplyr)
library(stringr)
library(ggplot2)
library(tibble)

# -------------------------
# USER SETTINGS
# -------------------------
base_dir <- "PATH/TO/YOUR/PARENT_DIRECTORY"
species_id <- 9913
string_version <- "12.0"
score_threshold <- 400
top_n_terms <- 8
string_input_directory <- NULL

gene_column_candidates <- c(
  "gene", "Gene", "symbol", "SYMBOL", "GeneSymbol",
  "genes", "external_gene_name", "hgnc_symbol"
)

# -------------------------
# HELPERS
# -------------------------
choose_first_existing <- function(x, candidates) {
  hit <- intersect(candidates, x)
  if (length(hit) == 0) return(NA_character_)
  hit[1]
}

find_gene_column <- function(df, candidates) {
  hit <- intersect(candidates, names(df))
  if (length(hit) > 0) return(hit[1])

  text_cols <- names(df)[vapply(df, function(x) is.character(x) || is.factor(x), logical(1))]
  if (length(text_cols) > 0) return(text_cols[1])

  stop("Could not identify a gene column. Available columns: ", paste(names(df), collapse = ", "))
}

read_gene_list <- function(file_path, gene_column_candidates) {
  df <- read_csv(file_path, show_col_types = FALSE)
  gene_col <- find_gene_column(df, gene_column_candidates)

  out <- data.frame(
    gene = as.character(df[[gene_col]]),
    stringsAsFactors = FALSE
  )

  out$gene <- trimws(out$gene)
  out <- out[!is.na(out$gene) & out$gene != "", , drop = FALSE]
  out <- unique(out)
  rownames(out) <- NULL
  out
}

standardize_enrichment_df <- function(enrichment_df) {
  if (is.null(enrichment_df) || nrow(enrichment_df) == 0) return(data.frame())

  df <- as.data.frame(enrichment_df, stringsAsFactors = FALSE)

  category_col <- choose_first_existing(names(df), c("category", "term_category", "source"))
  term_col <- choose_first_existing(names(df), c("description", "term", "term_description"))
  term_id_col <- choose_first_existing(names(df), c("term_id", "term", "id"))
  fdr_col <- choose_first_existing(names(df), c("fdr", "FDR", "false_discovery_rate"))
  p_col <- choose_first_existing(names(df), c("p_value", "pvalue", "p.value"))
  pref_col <- choose_first_existing(names(df), c("preferredNames"))
  input_col <- choose_first_existing(names(df), c("inputGenes"))

  if (is.na(category_col) || is.na(term_col)) return(data.frame())

  out <- data.frame(
    category_std = as.character(df[[category_col]]),
    term_std = as.character(df[[term_col]]),
    term_id_std = if (!is.na(term_id_col)) as.character(df[[term_id_col]]) else as.character(df[[term_col]]),
    fdr_std = if (!is.na(fdr_col)) suppressWarnings(as.numeric(df[[fdr_col]])) else NA_real_,
    p_std = if (!is.na(p_col)) suppressWarnings(as.numeric(df[[p_col]])) else NA_real_,
    preferredNames = if (!is.na(pref_col)) as.character(df[[pref_col]]) else NA_character_,
    inputGenes = if (!is.na(input_col)) as.character(df[[input_col]]) else NA_character_,
    stringsAsFactors = FALSE
  )

  out$score_for_plot <- ifelse(
    !is.na(out$fdr_std) & out$fdr_std > 0,
    -log10(out$fdr_std),
    ifelse(!is.na(out$p_std) & out$p_std > 0, -log10(out$p_std), NA_real_)
  )

  out
}

extract_go_bp_terms <- function(enrichment_std, top_n_terms) {
  if (nrow(enrichment_std) == 0) return(data.frame())

  out <- enrichment_std[
    grepl("process|biological process|gobp|go biological process",
          tolower(enrichment_std$category_std)) &
      !is.na(enrichment_std$score_for_plot),
    ,
    drop = FALSE
  ]

  out <- out[order(out$score_for_plot, decreasing = TRUE), , drop = FALSE]
  out <- utils::head(out, top_n_terms)
  rownames(out) <- NULL
  out
}

split_members <- function(x) {
  if (length(x) == 0 || is.na(x) || !nzchar(x)) return(character(0))
  y <- unlist(strsplit(x, "[,;]"))
  y <- trimws(y)
  y[y != ""]
}

extract_term_gene_membership <- function(go_terms_df) {
  if (nrow(go_terms_df) == 0) return(data.frame())

  out_list <- list()

  for (i in seq_len(nrow(go_terms_df))) {
    row_i <- go_terms_df[i, , drop = FALSE]

    genes_from_pref <- split_members(row_i$preferredNames[1])
    genes_from_input <- split_members(row_i$inputGenes[1])

    genes <- if (length(genes_from_pref) > 0) genes_from_pref else genes_from_input
    if (length(genes) == 0) next

    out_list[[length(out_list) + 1]] <- data.frame(
      term_std = rep(as.character(row_i$term_std[1]), length(genes)),
      term_id_std = rep(as.character(row_i$term_id_std[1]), length(genes)),
      gene = as.character(genes),
      stringsAsFactors = FALSE
    )
  }

  if (length(out_list) == 0) return(data.frame())

  out <- do.call(rbind, out_list)
  out <- unique(out)
  rownames(out) <- NULL
  out
}

run_one_enrichment <- function(file_path, contrast_name, direction, string_db, gene_column_candidates, top_n_terms) {
  genes_df <- read_gene_list(file_path, gene_column_candidates)

  if (nrow(genes_df) == 0) {
    return(list(
      bars = data.frame(),
      members = data.frame(),
      mapped = data.frame(),
      enrich = data.frame()
    ))
  }

  map_input <- data.frame(
    gene = as.character(genes_df$gene),
    stringsAsFactors = FALSE
  )

  mapped <- tryCatch(
    string_db$map(map_input, "gene", removeUnmappedRows = TRUE),
    error = function(e) e
  )

  if (inherits(mapped, "error")) {
    message("Mapping failed for ", contrast_name, " ", direction, ": ", conditionMessage(mapped))
    return(list(
      bars = data.frame(),
      members = data.frame(),
      mapped = data.frame(),
      enrich = data.frame()
    ))
  }

  mapped <- as.data.frame(mapped, stringsAsFactors = FALSE)

  if (!"STRING_id" %in% names(mapped) || nrow(mapped) == 0) {
    return(list(
      bars = data.frame(),
      members = data.frame(),
      mapped = mapped,
      enrich = data.frame()
    ))
  }

  enrich_raw <- tryCatch(
    string_db$get_enrichment(unique(mapped$STRING_id), category = "Process"),
    error = function(e) e
  )

  if (inherits(enrich_raw, "error")) {
    message("Enrichment failed for ", contrast_name, " ", direction, ": ", conditionMessage(enrich_raw))
    return(list(
      bars = data.frame(),
      members = data.frame(),
      mapped = mapped,
      enrich = data.frame()
    ))
  }

  enrich_std <- standardize_enrichment_df(enrich_raw)
  go_terms <- extract_go_bp_terms(enrich_std, top_n_terms)

  if (nrow(go_terms) == 0) {
    return(list(
      bars = data.frame(),
      members = data.frame(),
      mapped = mapped,
      enrich = enrich_std
    ))
  }

  bars <- data.frame(
    contrast = rep(as.character(contrast_name), nrow(go_terms)),
    direction = rep(as.character(direction), nrow(go_terms)),
    term_std = as.character(go_terms$term_std),
    term_id_std = as.character(go_terms$term_id_std),
    score_for_plot = as.numeric(go_terms$score_for_plot),
    stringsAsFactors = FALSE
  )

  members <- extract_term_gene_membership(go_terms)

  if (nrow(members) > 0) {
    members$contrast <- contrast_name
    members$direction <- direction
    members <- members[, c("contrast", "direction", "term_std", "term_id_std", "gene")]
    rownames(members) <- NULL
  }

  list(
    bars = bars,
    members = members,
    mapped = mapped,
    enrich = enrich_std
  )
}

# -------------------------
# INIT STRING
# -------------------------
string_db <- if (is.null(string_input_directory)) {
  STRINGdb$new(
    version = string_version,
    species = species_id,
    score_threshold = score_threshold
  )
} else {
  STRINGdb$new(
    version = string_version,
    species = species_id,
    score_threshold = score_threshold,
    input_directory = string_input_directory
  )
}

# -------------------------
# FIND FILES
# -------------------------
up_files <- list.files(
  path = base_dir,
  pattern = "^UP_sig\\.csv$",
  recursive = TRUE,
  full.names = TRUE
)

down_files <- list.files(
  path = base_dir,
  pattern = "^DOWN_sig\\.csv$",
  recursive = TRUE,
  full.names = TRUE
)

contrasts <- sort(unique(c(
  basename(dirname(up_files)),
  basename(dirname(down_files))
)))

# -------------------------
# RUN
# -------------------------
all_bars <- list()
all_members <- list()
all_enrich <- list()
mapping_summary <- list()

for (ctr in contrasts) {
  message("Processing: ", ctr)

  up_match <- up_files[basename(dirname(up_files)) == ctr]
  down_match <- down_files[basename(dirname(down_files)) == ctr]

  up_file <- if (length(up_match) >= 1) up_match[1] else NA_character_
  down_file <- if (length(down_match) >= 1) down_match[1] else NA_character_

  if (!is.na(up_file) && file.exists(up_file)) {
    up_input_n <- nrow(read_gene_list(up_file, gene_column_candidates))
    up_res <- run_one_enrichment(
      file_path = up_file,
      contrast_name = ctr,
      direction = "UP",
      string_db = string_db,
      gene_column_candidates = gene_column_candidates,
      top_n_terms = top_n_terms
    )

    all_bars[[length(all_bars) + 1]] <- up_res$bars
    all_members[[length(all_members) + 1]] <- up_res$members

    if (nrow(up_res$enrich) > 0) {
      tmp_enrich <- up_res$enrich
      tmp_enrich$contrast <- ctr
      tmp_enrich$direction <- "UP"
      all_enrich[[length(all_enrich) + 1]] <- tmp_enrich
    }

    mapping_summary[[length(mapping_summary) + 1]] <- tibble(
      contrast = ctr,
      direction = "UP",
      input_genes = up_input_n,
      mapped_genes = nrow(up_res$mapped)
    )
  }

  if (!is.na(down_file) && file.exists(down_file)) {
    down_input_n <- nrow(read_gene_list(down_file, gene_column_candidates))
    down_res <- run_one_enrichment(
      file_path = down_file,
      contrast_name = ctr,
      direction = "DOWN",
      string_db = string_db,
      gene_column_candidates = gene_column_candidates,
      top_n_terms = top_n_terms
    )

    all_bars[[length(all_bars) + 1]] <- down_res$bars
    all_members[[length(all_members) + 1]] <- down_res$members

    if (nrow(down_res$enrich) > 0) {
      tmp_enrich <- down_res$enrich
      tmp_enrich$contrast <- ctr
      tmp_enrich$direction <- "DOWN"
      all_enrich[[length(all_enrich) + 1]] <- tmp_enrich
    }

    mapping_summary[[length(mapping_summary) + 1]] <- tibble(
      contrast = ctr,
      direction = "DOWN",
      input_genes = down_input_n,
      mapped_genes = nrow(down_res$mapped)
    )
  }
}

bars_df <- if (length(all_bars) > 0) bind_rows(all_bars) else data.frame()
members_df <- if (length(all_members) > 0) bind_rows(all_members) else data.frame()
mapping_df <- if (length(mapping_summary) > 0) bind_rows(mapping_summary) else data.frame()
enrich_df <- if (length(all_enrich) > 0) bind_rows(all_enrich) else data.frame()

if (nrow(mapping_df) > 0) {
  write_csv(mapping_df, file.path(base_dir, "STRING_mapping_summary.csv"))
}

if (nrow(enrich_df) > 0) {
  write_csv(enrich_df, file.path(base_dir, "STRING_full_enrichment_debug.csv"))
}

if (nrow(bars_df) == 0) {
  message("No GO BP enrichment results were found across any comparisons.")
  quit(save = "no")
}

# -------------------------
# PANEL LABELS
# -------------------------
bars_df <- as.data.frame(bars_df, stringsAsFactors = FALSE)
bars_df$contrast <- as.character(bars_df$contrast)
bars_df$direction <- as.character(bars_df$direction)
bars_df$term_std <- as.character(bars_df$term_std)
bars_df$term_id_std <- as.character(bars_df$term_id_std)
bars_df$score_for_plot <- as.numeric(bars_df$score_for_plot)

bars_df$panel_name <- ifelse(
  bars_df$direction == "DOWN",
  paste0(bars_df$contrast, "_inverse"),
  bars_df$contrast
)

panel_order <- as.vector(rbind(contrasts, paste0(contrasts, "_inverse")))
panel_order <- panel_order[panel_order %in% unique(bars_df$panel_name)]

bars_df$panel_name <- factor(bars_df$panel_name, levels = panel_order)
bars_df$panel_term <- paste(as.character(bars_df$panel_name), bars_df$term_std, sep = "___")
term_levels <- unique(bars_df$panel_term)
bars_df$panel_term <- factor(bars_df$panel_term, levels = rev(term_levels))

label_map <- setNames(as.character(bars_df$term_std), as.character(bars_df$panel_term))

# -------------------------
# PUBLICATION LABELS
# Edit this named vector as needed
# -------------------------
publication_labels <- c(
  # "A_vs_B" = "A vs B",
  # "A_vs_B_inverse" = "A vs B inverse",
  # "B_vs_C" = "B vs C",
  # "B_vs_C_inverse" = "B vs C inverse"
)

panel_labels_used <- setNames(as.character(panel_order), panel_order)
if (length(publication_labels) > 0) {
  matched <- intersect(names(publication_labels), names(panel_labels_used))
  panel_labels_used[matched] <- publication_labels[matched]
}

# -------------------------
# SAVE GENE MEMBERSHIP TABLE
# -------------------------
if (nrow(members_df) > 0) {
  members_df <- as.data.frame(members_df, stringsAsFactors = FALSE)
  members_df$contrast <- as.character(members_df$contrast)
  members_df$direction <- as.character(members_df$direction)
  members_df$term_std <- as.character(members_df$term_std)
  members_df$term_id_std <- as.character(members_df$term_id_std)
  members_df$gene <- as.character(members_df$gene)

  members_df$panel_name <- ifelse(
    members_df$direction == "DOWN",
    paste0(members_df$contrast, "_inverse"),
    members_df$contrast
  )

  members_df$panel_label <- panel_labels_used[as.character(members_df$panel_name)]

  members_df <- members_df[, c(
    "contrast", "direction", "panel_name", "panel_label",
    "term_std", "term_id_std", "gene"
  )]

  write_csv(members_df, file.path(base_dir, "STRING_GO_BP_gene_membership_table.csv"))
}

# -------------------------
# PLOT
# -------------------------
max_x <- max(bars_df$score_for_plot, na.rm = TRUE)

p <- ggplot(bars_df, aes(x = score_for_plot, y = panel_term)) +
  geom_col(width = 0.7) +
  facet_wrap(
    ~ panel_name,
    nrow = 1,
    scales = "fixed",
    labeller = as_labeller(panel_labels_used)
  ) +
  scale_y_discrete(labels = label_map) +
  scale_x_continuous(
    limits = c(0, max_x * 1.05),
    expand = c(0, 0)
  ) +
  labs(
    title = "STRING GO Biological Process enrichment",
    x = expression(-log[10]("significance")),
    y = NULL
  ) +
  theme_bw() +
  theme(
    strip.background = element_rect(fill = "white"),
    panel.grid.major.y = element_blank(),
    axis.text.y = element_text(size = 8),
    axis.ticks.y = element_line(),
    strip.text = element_text(size = 10)
  )

print(p)

ggsave(
  filename = file.path(base_dir, "STRING_GO_BP_side_by_side_bars_only.png"),
  plot = p,
  width = max(16, length(panel_order) * 3.5),
  height = max(8, length(unique(bars_df$panel_term)) * 0.25),
  dpi = 300,
  bg = "white"
)

write_csv(bars_df, file.path(base_dir, "STRING_GO_BP_bar_data.csv"))
