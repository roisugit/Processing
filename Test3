dbg <- function(...) cat(..., "\n")

choose_first_existing <- function(x, candidates) {
  hit <- intersect(candidates, x)
  if (length(hit) == 0) return(NA_character_)
  hit[1]
}

find_gene_column <- function(df, candidates) {
  hit <- intersect(candidates, names(df))
  if (length(hit) > 0) return(hit[1])

  text_cols <- names(df)[vapply(df, function(x) is.character(x) || is.factor(x), logical(1))]
  if (length(text_cols) > 0) return(text_cols[1])

  stop("Could not identify a gene column. Available columns: ", paste(names(df), collapse = ", "))
}

read_gene_list <- function(file_path, gene_column_candidates) {
  df <- read_csv(file_path, show_col_types = FALSE)
  gene_col <- find_gene_column(df, gene_column_candidates)

  out <- data.frame(
    gene = as.character(df[[gene_col]]),
    stringsAsFactors = FALSE
  )

  out$gene <- trimws(out$gene)
  out <- out[!is.na(out$gene) & out$gene != "", , drop = FALSE]
  out <- unique(out)
  rownames(out) <- NULL
  out
}

standardize_enrichment_df <- function(enrichment_df) {
  if (is.null(enrichment_df) || nrow(enrichment_df) == 0) return(data.frame())

  df <- as.data.frame(enrichment_df, stringsAsFactors = FALSE)

  category_col <- choose_first_existing(names(df), c("category", "term_category", "source"))
  term_col <- choose_first_existing(names(df), c("description", "term", "term_description"))
  term_id_col <- choose_first_existing(names(df), c("term_id", "term", "id"))
  fdr_col <- choose_first_existing(names(df), c("fdr", "FDR", "false_discovery_rate"))
  p_col <- choose_first_existing(names(df), c("p_value", "pvalue", "p.value"))

  if (is.na(category_col) || is.na(term_col)) return(data.frame())

  out <- data.frame(
    category_std = as.character(df[[category_col]]),
    term_std = as.character(df[[term_col]]),
    term_id_std = if (!is.na(term_id_col)) as.character(df[[term_id_col]]) else as.character(df[[term_col]]),
    fdr_std = if (!is.na(fdr_col)) suppressWarnings(as.numeric(df[[fdr_col]])) else NA_real_,
    p_std = if (!is.na(p_col)) suppressWarnings(as.numeric(df[[p_col]])) else NA_real_,
    stringsAsFactors = FALSE
  )

  out$score_for_plot <- ifelse(
    !is.na(out$fdr_std) & out$fdr_std > 0,
    -log10(out$fdr_std),
    ifelse(!is.na(out$p_std) & out$p_std > 0, -log10(out$p_std), NA_real_)
  )

  out
}

extract_go_bp_terms <- function(enrichment_std, top_n_terms) {
  if (nrow(enrichment_std) == 0) return(data.frame())

  out <- enrichment_std[
    grepl("process|biological process|gobp|go biological process",
          tolower(enrichment_std$category_std)) &
      !is.na(enrichment_std$score_for_plot) &
      grepl("^GO:", enrichment_std$term_id_std),
    ,
    drop = FALSE
  ]

  out <- out[order(out$score_for_plot, decreasing = TRUE), , drop = FALSE]
  out <- utils::head(out, top_n_terms)
  rownames(out) <- NULL
  out
}

# -------------------------
# STRING API: get proteins for one functional term
# Docs: /api/[format]/functional_terms?term_text=...&species=...
# -------------------------
get_term_members_from_api <- function(go_id, species_id, caller_identity = NULL) {
  base_url <- "https://string-db.org/api/json/functional_terms"

  query <- list(
    term_text = go_id,
    species = species_id
  )

  if (!is.null(caller_identity)) {
    query$caller_identity <- caller_identity
  }

  resp <- tryCatch(
    httr::GET(base_url, query = query),
    error = function(e) e
  )

  if (inherits(resp, "error")) {
    message("API request failed for ", go_id, ": ", conditionMessage(resp))
    return(data.frame())
  }

  if (httr::status_code(resp) != 200) {
    message("API returned HTTP ", httr::status_code(resp), " for ", go_id)
    return(data.frame())
  }

  txt <- httr::content(resp, as = "text", encoding = "UTF-8")
  if (!nzchar(txt)) return(data.frame())

  parsed <- tryCatch(
    jsonlite::fromJSON(txt, flatten = TRUE),
    error = function(e) e
  )

  if (inherits(parsed, "error")) {
    message("Could not parse API JSON for ", go_id, ": ", conditionMessage(parsed))
    return(data.frame())
  }

  df <- as.data.frame(parsed, stringsAsFactors = FALSE)
  if (nrow(df) == 0) return(data.frame())

  # best-effort standardization across possible field names
  string_col <- choose_first_existing(names(df), c("stringId", "stringId_A", "string_id", "protein_external_id"))
  pref_col   <- choose_first_existing(names(df), c("preferredName", "preferred_name", "preferredName_A", "preferred_name_A"))
  term_col   <- choose_first_existing(names(df), c("term", "description", "term_description"))
  termid_col <- choose_first_existing(names(df), c("termId", "term_id", "id"))

  out <- data.frame(
    term_id_std = if (!is.na(termid_col)) as.character(df[[termid_col]]) else go_id,
    term_std = if (!is.na(term_col)) as.character(df[[term_col]]) else go_id,
    STRING_id = if (!is.na(string_col)) as.character(df[[string_col]]) else NA_character_,
    preferred_name = if (!is.na(pref_col)) as.character(df[[pref_col]]) else NA_character_,
    stringsAsFactors = FALSE
  )

  out <- out[!is.na(out$STRING_id) & out$STRING_id != "", , drop = FALSE]
  out <- unique(out)
  rownames(out) <- NULL
  out
}

run_one_enrichment <- function(file_path, contrast_name, direction, string_db, gene_column_candidates, top_n_terms, species_id, caller_identity) {
  dbg("Running:", contrast_name, direction, file_path)

  genes_df <- read_gene_list(file_path, gene_column_candidates)
  if (nrow(genes_df) == 0) {
    return(list(bars = data.frame(), dots = data.frame(), mapped = data.frame()))
  }

  map_input <- data.frame(
    gene = as.character(genes_df$gene),
    stringsAsFactors = FALSE
  )
  rownames(map_input) <- NULL

  mapped <- tryCatch(
    string_db$map(map_input, "gene", removeUnmappedRows = TRUE),
    error = function(e) e
  )

  if (inherits(mapped, "error")) {
    message("Mapping failed for ", contrast_name, " ", direction, ": ", conditionMessage(mapped))
    return(list(bars = data.frame(), dots = data.frame(), mapped = data.frame()))
  }

  mapped <- as.data.frame(mapped, stringsAsFactors = FALSE)
  if (!"STRING_id" %in% names(mapped) || nrow(mapped) == 0) {
    return(list(bars = data.frame(), dots = data.frame(), mapped = mapped))
  }

  enrich_raw <- tryCatch(
    string_db$get_enrichment(unique(mapped$STRING_id)),
    error = function(e) e
  )

  if (inherits(enrich_raw, "error")) {
    message("Enrichment failed for ", contrast_name, " ", direction, ": ", conditionMessage(enrich_raw))
    return(list(bars = data.frame(), dots = data.frame(), mapped = mapped))
  }

  enrich_std <- standardize_enrichment_df(enrich_raw)
  go_terms <- extract_go_bp_terms(enrich_std, top_n_terms)

  if (nrow(go_terms) == 0) {
    return(list(bars = data.frame(), dots = data.frame(), mapped = mapped))
  }

  bars <- data.frame(
    contrast = rep(as.character(contrast_name), nrow(go_terms)),
    direction = rep(as.character(direction), nrow(go_terms)),
    term_std = as.character(go_terms$term_std),
    term_id_std = as.character(go_terms$term_id_std),
    score_for_plot = as.numeric(go_terms$score_for_plot),
    stringsAsFactors = FALSE
  )

  # API membership lookup for each GO term
  api_members_list <- lapply(go_terms$term_id_std, function(go_id) {
    get_term_members_from_api(go_id, species_id = species_id, caller_identity = caller_identity)
  })
  api_members <- bind_rows(api_members_list)

  if (nrow(api_members) == 0) {
    message("No API term members returned for ", contrast_name, " ", direction)
    return(list(bars = bars, dots = data.frame(), mapped = mapped))
  }

  # Intersect API-returned members with mapped genes from this comparison
  mapped2 <- mapped %>%
    transmute(
      gene = as.character(gene),
      STRING_id = as.character(STRING_id)
    ) %>%
    distinct()

  dots <- api_members %>%
    inner_join(mapped2, by = "STRING_id") %>%
    left_join(
      bars %>% select(contrast, direction, term_std, term_id_std, score_for_plot),
      by = c("term_id_std", "term_std")
    ) %>%
    mutate(
      contrast = as.character(contrast_name),
      direction = as.character(direction)
    ) %>%
    distinct(term_id_std, term_std, STRING_id, gene, .keep_all = TRUE)

  if (nrow(dots) > 0) {
    dots <- dots %>%
      group_by(contrast, direction, term_std) %>%
      mutate(
        gene_index = row_number(),
        n_genes = n(),
        dot_x = as.numeric(ifelse(
          n_genes == 1,
          score_for_plot / 2,
          score_for_plot * (gene_index / (n_genes + 1))
        ))
      ) %>%
      ungroup() %>%
      select(contrast, direction, term_std, term_id_std, gene, STRING_id, dot_x)
  }

  list(
    bars = bars,
    dots = as.data.frame(dots, stringsAsFactors = FALSE),
    mapped = mapped
  )
}

