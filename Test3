all_bars <- list()
all_dots <- list()

for (cmp in comparison_names) {
  message("Processing comparison: ", cmp)

  up_matches <- up_files[basename(dirname(up_files)) == cmp]
  down_matches <- down_files[basename(dirname(down_files)) == cmp]

  up_file <- if (length(up_matches) >= 1) up_matches[1] else NA_character_
  down_file <- if (length(down_matches) >= 1) down_matches[1] else NA_character_

  if (!is.na(up_file) && file.exists(up_file)) {
    up_res <- run_one_enrichment(
      file_path = up_file,
      comparison_name = cmp,
      direction = "UP",
      string_db = string_db,
      gene_column_candidates = gene_column_candidates,
      top_n_terms = top_n_terms
    )
    all_bars[[length(all_bars) + 1]] <- up_res$bars
    all_dots[[length(all_dots) + 1]] <- up_res$dots
  }

  if (!is.na(down_file) && file.exists(down_file)) {
    down_res <- run_one_enrichment(
      file_path = down_file,
      comparison_name = cmp,
      direction = "DOWN",
      string_db = string_db,
      gene_column_candidates = gene_column_candidates,
      top_n_terms = top_n_terms
    )
    all_bars[[length(all_bars) + 1]] <- down_res$bars
    all_dots[[length(all_dots) + 1]] <- down_res$dots
  }
}

