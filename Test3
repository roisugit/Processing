choose_first_existing <- function(x, candidates) {
  hit <- intersect(candidates, x)
  if (length(hit) == 0) return(NA_character_)
  hit[1]
}

find_gene_column <- function(df, candidates) {
  hit <- intersect(candidates, names(df))
  if (length(hit) > 0) return(hit[1])

  text_cols <- names(df)[vapply(df, function(x) is.character(x) || is.factor(x), logical(1))]
  if (length(text_cols) > 0) return(text_cols[1])

  stop("Could not identify a gene column. Available columns: ", paste(names(df), collapse = ", "))
}

read_gene_list <- function(file_path, gene_column_candidates) {
  df <- read_csv(file_path, show_col_types = FALSE)
  gene_col <- find_gene_column(df, gene_column_candidates)

  tibble(
    gene = as.character(df[[gene_col]])
  ) %>%
    mutate(gene = str_trim(gene)) %>%
    filter(!is.na(gene), gene != "") %>%
    distinct()
}

extract_go_gene_string <- function(df_row) {
  candidate_cols <- c(
    "preferredNames",
    "preferred_names",
    "inputGenes",
    "genes",
    "gene_names",
    "matching proteins",
    "matching_proteins"
  )

  existing <- intersect(candidate_cols, names(df_row))
  if (length(existing) == 0) return(NA_character_)

  val <- df_row[[existing[1]]][1]
  if (is.null(val) || length(val) == 0 || is.na(val)) return(NA_character_)

  as.character(val)
}

split_gene_membership <- function(x) {
  if (is.na(x) || x == "") return(character(0))
  parts <- unlist(strsplit(x, "[,;]"))
  parts <- trimws(parts)
  unique(parts[parts != ""])
}

standardize_enrichment_df <- function(enrichment_df) {
  if (is.null(enrichment_df) || nrow(enrichment_df) == 0) return(tibble())

  df <- as_tibble(enrichment_df)

  category_col <- choose_first_existing(names(df), c("category", "term_category", "source"))
  term_col <- choose_first_existing(names(df), c("description", "term", "term_description"))
  term_id_col <- choose_first_existing(names(df), c("term_id", "term", "id"))
  fdr_col <- choose_first_existing(names(df), c("fdr", "FDR", "false_discovery_rate"))
  p_col <- choose_first_existing(names(df), c("p_value", "pvalue", "p.value"))

  if (is.na(category_col) || is.na(term_col)) return(tibble())

  df %>%
    mutate(
      category_std = as.character(.data[[category_col]]),
      term_std = as.character(.data[[term_col]]),
      term_id_std = if (!is.na(term_id_col)) as.character(.data[[term_id_col]]) else term_std,
      fdr_std = if (!is.na(fdr_col)) suppressWarnings(as.numeric(.data[[fdr_col]])) else NA_real_,
      p_std = if (!is.na(p_col)) suppressWarnings(as.numeric(.data[[p_col]])) else NA_real_
    ) %>%
    mutate(
      score_for_plot = dplyr::case_when(
        !is.na(fdr_std) & fdr_std > 0 ~ -log10(fdr_std),
        !is.na(p_std) & p_std > 0 ~ -log10(p_std),
        TRUE ~ NA_real_
      )
    )
}

extract_go_bp_terms <- function(enrichment_std, top_n_terms) {
  if (nrow(enrichment_std) == 0) return(tibble())

  enrichment_std %>%
    filter(str_detect(tolower(category_std), "process|biological process|gobp|go biological process")) %>%
    filter(!is.na(score_for_plot)) %>%
    arrange(desc(score_for_plot)) %>%
    slice_head(n = top_n_terms)
}

extract_term_gene_membership <- function(go_terms_df) {
  if (nrow(go_terms_df) == 0) return(tibble())

  out <- lapply(seq_len(nrow(go_terms_df)), function(i) {
    row_i <- go_terms_df[i, , drop = FALSE]
    genes_str <- extract_go_gene_string(row_i)
    genes <- split_gene_membership(genes_str)

    if (length(genes) == 0) return(NULL)

    tibble(
      term_std = row_i$term_std[[1]],
      term_id_std = row_i$term_id_std[[1]],
      gene = genes
    )
  })

  bind_rows(out) %>% distinct()
}

run_one_enrichment <- function(file_path, contrast_name, direction, string_db, gene_column_candidates, top_n_terms) {
  genes_df <- read_gene_list(file_path, gene_column_candidates)

  if (nrow(genes_df) == 0) {
    return(list(bars = tibble(), dots = tibble(), mapped = tibble()))
  }

  map_input <- data.frame(
    gene = genes_df$gene,
    stringsAsFactors = FALSE
  )

  mapped <- tryCatch(
    string_db$map(map_input, "gene", removeUnmappedRows = TRUE),
    error = function(e) NULL
  )

  if (is.null(mapped)) {
    return(list(bars = tibble(), dots = tibble(), mapped = tibble()))
  }

  mapped <- as.data.frame(mapped, stringsAsFactors = FALSE)

  if (!"STRING_id" %in% names(mapped) || nrow(mapped) == 0) {
    return(list(bars = tibble(), dots = tibble(), mapped = mapped))
  }

  enrich_raw <- tryCatch(
    string_db$get_enrichment(unique(mapped$STRING_id)),
    error = function(e) NULL
  )

  enrich_std <- standardize_enrichment_df(enrich_raw)
  go_terms <- extract_go_bp_terms(enrich_std, top_n_terms)

  if (nrow(go_terms) == 0) {
    return(list(bars = tibble(), dots = tibble(), mapped = mapped))
  }

  bars <- go_terms %>%
    transmute(
      contrast = as.character(contrast_name),
      direction = as.character(direction),
      term_std = as.character(term_std),
      term_id_std = as.character(term_id_std),
      score_for_plot = as.numeric(score_for_plot)
    )

  membership <- extract_term_gene_membership(go_terms)

  if (nrow(membership) == 0) {
    dots <- tibble()
  } else {
    dots <- membership %>%
      semi_join(mapped %>% distinct(gene), by = "gene") %>%
      left_join(
        bars %>% select(contrast, direction, term_std, score_for_plot),
        by = "term_std"
      ) %>%
      group_by(contrast, direction, term_std) %>%
      mutate(
        gene_index = dplyr::row_number(),
        n_genes = dplyr::n(),
        dot_x = as.numeric(ifelse(
          n_genes == 1,
          score_for_plot / 2,
          score_for_plot * (gene_index / (n_genes + 1))
        ))
      ) %>%
      ungroup()
  }

  list(
    bars = bars,
    dots = dots,
    mapped = mapped
  )
}

