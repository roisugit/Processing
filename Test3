dbg_sep <- function(title = "") {
  cat("\n")
  cat(paste(rep("=", 80), collapse = ""), "\n")
  if (nzchar(title)) cat(title, "\n")
  cat(paste(rep("=", 80), collapse = ""), "\n")
}

dbg_print <- function(name, x, max_rows = 6) {
  cat("\n---", name, "---\n")
  cat("class:", paste(class(x), collapse = ", "), "\n")
  cat("typeof:", typeof(x), "\n")
  if (!is.null(dim(x))) {
    cat("dim:", paste(dim(x), collapse = " x "), "\n")
  } else {
    cat("length:", length(x), "\n")
  }

  if (is.data.frame(x) || tibble::is_tibble(x)) {
    cat("names:", paste(names(x), collapse = ", "), "\n")
    print(utils::head(x, max_rows))
    cat("\nstr():\n")
    str(x)
  } else {
    print(utils::head(x, max_rows))
    cat("\nstr():\n")
    str(x)
  }
}

find_gene_column <- function(df, candidates) {
  hits <- intersect(candidates, names(df))
  if (length(hits) > 0) return(hits[1])

  text_cols <- names(df)[vapply(df, function(x) is.character(x) || is.factor(x), logical(1))]
  if (length(text_cols) > 0) return(text_cols[1])

  stop("Could not identify a gene column. Available columns: ", paste(names(df), collapse = ", "))
}

safe_read_csv <- function(file_path) {
  tryCatch(
    readr::read_csv(file_path, show_col_types = FALSE),
    error = function(e) {
      cat("READ ERROR:", conditionMessage(e), "\n")
      NULL
    }
  )
}

make_plain_map_input <- function(genes) {
  out <- data.frame(
    gene = as.character(genes),
    stringsAsFactors = FALSE
  )

  out <- out[
    !is.na(out$gene) & trimws(out$gene) != "",
    ,
    drop = FALSE
  ]

  out$gene <- trimws(out$gene)
  out <- unique(out)

  rownames(out) <- NULL
  out
}

