# -------------------------
# DEBUG LOG
# -------------------------
debug_log <- list()

# -------------------------
# PROCESS FILES ONE BY ONE
# -------------------------
for (i in seq_along(all_files)) {
  file_path <- all_files[i]
  contrast_name <- basename(dirname(file_path))
  direction <- basename(file_path)

  dbg_sep(paste0("PROCESSING FILE ", i, " / ", length(all_files)))
  cat("file_path   :", file_path, "\n")
  cat("contrast    :", contrast_name, "\n")
  cat("direction   :", direction, "\n")

  log_row <- tibble(
    file_path = file_path,
    contrast = contrast_name,
    file_name = direction,
    status = "started",
    gene_col = NA_character_,
    input_rows = NA_integer_,
    input_unique_genes = NA_integer_,
    mapped_rows = NA_integer_,
    mapped_unique_string = NA_integer_,
    unmapped_rows = NA_integer_,
    error_stage = NA_character_,
    error_message = NA_character_
  )

  # ---- read file ----
  dbg_sep("READING CSV")
  df <- safe_read_csv(file_path)

  if (is.null(df)) {
    log_row$status <- "failed"
    log_row$error_stage <- "read_csv"
    log_row$error_message <- "Failed to read CSV"
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  dbg_print("raw_df", df)

  # ---- find gene column ----
  dbg_sep("IDENTIFYING GENE COLUMN")
  gene_col <- tryCatch(
    find_gene_column(df, gene_column_candidates),
    error = function(e) e
  )

  if (inherits(gene_col, "error")) {
    cat("GENE COLUMN ERROR:", conditionMessage(gene_col), "\n")
    log_row$status <- "failed"
    log_row$error_stage <- "find_gene_column"
    log_row$error_message <- conditionMessage(gene_col)
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  cat("Chosen gene column:", gene_col, "\n")
  log_row$gene_col <- gene_col

  dbg_sep("EXTRACTING GENE VECTOR")
  gene_vec <- tryCatch(
    as.character(df[[gene_col]]),
    error = function(e) e
  )

  if (inherits(gene_vec, "error")) {
    cat("GENE EXTRACTION ERROR:", conditionMessage(gene_vec), "\n")
    log_row$status <- "failed"
    log_row$error_stage <- "extract_gene_vector"
    log_row$error_message <- conditionMessage(gene_vec)
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  dbg_print("gene_vec_raw", gene_vec)

  # ---- build map input ----
  dbg_sep("BUILDING MAP INPUT")
  map_input <- tryCatch(
    make_plain_map_input(gene_vec),
    error = function(e) e
  )

  if (inherits(map_input, "error")) {
    cat("MAP INPUT ERROR:", conditionMessage(map_input), "\n")
    log_row$status <- "failed"
    log_row$error_stage <- "make_plain_map_input"
    log_row$error_message <- conditionMessage(map_input)
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  dbg_print("map_input", map_input)

  log_row$input_rows <- nrow(map_input)
  log_row$input_unique_genes <- dplyr::n_distinct(map_input$gene)

  if (nrow(map_input) == 0) {
    cat("No valid genes after cleaning.\n")
    log_row$status <- "failed"
    log_row$error_stage <- "empty_map_input"
    log_row$error_message <- "No valid genes after cleaning"
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  cat("First 20 genes going into STRINGdb$map():\n")
  print(utils::head(map_input$gene, 20))

  cat("Any NA in gene column? ", any(is.na(map_input$gene)), "\n")
  cat("Any blank genes? ", any(trimws(map_input$gene) == ""), "\n")
  cat("Any duplicated genes? ", any(duplicated(map_input$gene)), "\n")

  # ---- test a tiny subset first ----
  dbg_sep("TESTING STRINGdb$map() ON FIRST 5 GENES")
  tiny_input <- utils::head(map_input, 5)
  dbg_print("tiny_input", tiny_input)

  tiny_map <- tryCatch(
    string_db$map(tiny_input, "gene", removeUnmappedRows = FALSE),
    error = function(e) e
  )

  if (inherits(tiny_map, "error")) {
    cat("TINY MAP ERROR:", conditionMessage(tiny_map), "\n")
    log_row$status <- "failed"
    log_row$error_stage <- "tiny_map"
    log_row$error_message <- conditionMessage(tiny_map)
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  dbg_print("tiny_map_result", tiny_map)

  # ---- full mapping ----
  dbg_sep("RUNNING FULL STRINGdb$map()")
  mapped <- tryCatch(
    string_db$map(map_input, "gene", removeUnmappedRows = FALSE),
    error = function(e) e
  )

  if (inherits(mapped, "error")) {
    cat("FULL MAP ERROR:", conditionMessage(mapped), "\n")
    cat("Attempting line-by-line debug mapping on first 20 genes...\n")

    # line-by-line debug
    per_gene_results <- vector("list", min(20, nrow(map_input)))
    for (j in seq_len(min(20, nrow(map_input)))) {
      one_gene <- data.frame(gene = map_input$gene[j], stringsAsFactors = FALSE)
      cat("\nTesting single gene [", j, "]: ", one_gene$gene, "\n", sep = "")
      one_res <- tryCatch(
        string_db$map(one_gene, "gene", removeUnmappedRows = FALSE),
        error = function(e) e
      )
      if (inherits(one_res, "error")) {
        cat("  -> single gene map ERROR:", conditionMessage(one_res), "\n")
        per_gene_results[[j]] <- tibble(
          gene = one_gene$gene,
          single_gene_status = "error",
          single_gene_message = conditionMessage(one_res)
        )
      } else {
        cat("  -> single gene map OK\n")
        per_gene_results[[j]] <- tibble(
          gene = one_gene$gene,
          single_gene_status = "ok",
          single_gene_message = NA_character_
        )
      }
    }

    single_gene_debug <- bind_rows(per_gene_results)
    dbg_print("single_gene_debug", single_gene_debug)
    write_csv(single_gene_debug, file.path(base_dir, paste0("DEBUG_single_gene_map_", contrast_name, "_", direction, ".csv")))

    log_row$status <- "failed"
    log_row$error_stage <- "full_map"
    log_row$error_message <- conditionMessage(mapped)
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  mapped <- as.data.frame(mapped, stringsAsFactors = FALSE)
  dbg_print("mapped_result", mapped)

  log_row$mapped_rows <- nrow(mapped)

  if ("STRING_id" %in% names(mapped)) {
    log_row$mapped_unique_string <- dplyr::n_distinct(mapped$STRING_id[!is.na(mapped$STRING_id)])
    log_row$unmapped_rows <- sum(is.na(mapped$STRING_id))
  } else {
    log_row$mapped_unique_string <- NA_integer_
    log_row$unmapped_rows <- NA_integer_
  }

  # ---- enrichment test ----
  dbg_sep("RUNNING ENRICHMENT")
  if ("STRING_id" %in% names(mapped)) {
    string_ids <- unique(mapped$STRING_id[!is.na(mapped$STRING_id)])
  } else {
    string_ids <- character(0)
  }

  dbg_print("string_ids", string_ids)

  if (length(string_ids) < 2) {
    cat("Not enough mapped STRING IDs for enrichment.\n")
    log_row$status <- "ok_no_enrichment"
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  enrichment <- tryCatch(
    string_db$get_enrichment(string_ids),
    error = function(e) e
  )

  if (inherits(enrichment, "error")) {
    cat("ENRICHMENT ERROR:", conditionMessage(enrichment), "\n")
    log_row$status <- "ok_map_enrichment_failed"
    log_row$error_stage <- "get_enrichment"
    log_row$error_message <- conditionMessage(enrichment)
    debug_log[[length(debug_log) + 1]] <- log_row
    next
  }

  enrichment <- as.data.frame(enrichment, stringsAsFactors = FALSE)
  dbg_print("enrichment_result", enrichment)

  cat("Enrichment column names:\n")
  print(names(enrichment))

  # ---- save per-file debug outputs ----
  dbg_sep("WRITING PER-FILE DEBUG OUTPUTS")
  safe_prefix <- paste0(
    "DEBUG_",
    gsub("[^A-Za-z0-9]+", "_", contrast_name),
    "_",
    gsub("[^A-Za-z0-9]+", "_", direction)
  )

  write_csv(as_tibble(map_input), file.path(base_dir, paste0(safe_prefix, "_map_input.csv")))
  write_csv(as_tibble(mapped), file.path(base_dir, paste0(safe_prefix, "_mapped.csv")))
  write_csv(as_tibble(enrichment), file.path(base_dir, paste0(safe_prefix, "_enrichment.csv")))

  log_row$status <- "ok"
  debug_log[[length(debug_log) + 1]] <- log_row
}

# -------------------------
# FINAL DEBUG SUMMARY
