#!/usr/bin/env python3

###################################################################################################################################################
# 48-core optimized + checks if all 5 files have different prefixes (before first '_')
###################################################################################################################################################

###################################################################################################################################################
# Installation
# install python to your computer
# pip install pandas
# pip install tqdm
###################################################################################################################################################

###################################################################################################################################################
# Dependencies
# Python #v3.8.20
# Below "base" means the base software included with python
# We list the versions of pandas and tqdm that we use, although newer or older versions may still work the same
import pandas as pd #v2.0.3 #pip install pandas
import os #base
from itertools import combinations #base
from multiprocessing import Pool, cpu_count #base
from tqdm import tqdm #v4.67.1 #pip install tqdm #progress bar
from datetime import datetime #base
import argparse #base
import sys #base
###################################################################################################################################################

###################################################################################################################################################
# Global variables for query, subject, and prefixes
# Query ECs for your target pathogen
query_ecs = None

# Subject ECs for your consortium candidates
# Each candidate is its own file ending in .csv and contains 1 column with the header "EC_ID"
subject_ecs = None

# Prefixes derived from the file names in query and subject folders
prefix_list = None
###################################################################################################################################################

###################################################################################################################################################
# Multiprocessing, create new variables for query, subject, and prefix
def init_worker(q_ecs, s_ecs, prefix_dict):
    global query_ecs, subject_ecs, prefix_list
    query_ecs = q_ecs
    subject_ecs = s_ecs
    prefix_list = prefix_dict
###################################################################################################################################################

###################################################################################################################################################
# Obtain Prefix for Unique Genera Assumption, obtain the string before the first instance of "_" (underscore)
# It is important that your file names have the format of "Genus_Species..."
def get_prefix(filename):
    return filename.split('_', 1)[0]
###################################################################################################################################################

###################################################################################################################################################
# Generate Combinations
def evaluate_combo(combo):
    combo = tuple(combo)
    combined = set()
    covered_query = set()

    # Setup combinations and comparisons
    for f in combo:
        ecs = subject_ecs[f]
        combined.update(ecs)
        covered_query.update(ecs & query_ecs)

    # Variables for EC overlap with target, EC fraction (total uniquely covered ECs with target divided by number of unique query ECs), and EC breadth
    query_count = len(covered_query)
    query_frac = query_count / len(query_ecs) if query_ecs else 0
    total_unique = len(combined)
    sorted_files = sorted(combo)
    
    # Prefix check
    prefixes = [prefix_list[f] for f in sorted_files]
    prefixes_all_different = "yes" if len(set(prefixes)) == 5 else "no"

    # Column names and data for output files
    return {
        'file1': sorted_files[0],
        'file2': sorted_files[1],
        'file3': sorted_files[2],
        'file4': sorted_files[3],
        'file5': sorted_files[4],
        'query_covered_count': query_count,
        'total_unique_ecs': total_unique
    }
###################################################################################################################################################

###################################################################################################################################################
# Load Query and Subject CSVs, check for existance of EC_ID column header in all query and subject csv files
def load_data(query_csv, subject_dir):
    print("Loading query ECs...")
    query_df = pd.read_csv(query_csv)
    if 'EC_ID' not in query_df.columns:
        raise ValueError("Query CSV must have 'EC_ID' column")
    q_ecs = set(query_df['EC_ID'].dropna().astype(str).str.strip())

    # Load subject file data and names
    print(f"Loading subject files from: {subject_dir}")
    subject_files = [f for f in os.listdir(subject_dir) if f.lower().endswith('.csv')]
    s_ecs = {}
    prefix_dict = {}

    # Get EC numbers from input files
    for file in tqdm(subject_files, desc="Loading subject CSVs"):
        path = os.path.join(subject_dir, file)
        try:
            df = pd.read_csv(path)
            if 'EC_ID' not in df.columns:
                continue
            ecs = set(df['EC_ID'].dropna().astype(str).str.strip())
            if not ecs:
                continue
            s_ecs[file] = ecs
            prefix_dict[file] = get_prefix(file)
        except Exception as e:
            print(f"Failed to read {file}: {e}")

    # Update user on stats
    print(f"Loaded {len(s_ecs)} valid subject files.")
    print(f"Query has {len(q_ecs)} unique EC numbers.\n")
    return q_ecs, s_ecs, prefix_dict
###################################################################################################################################################

###################################################################################################################################################
# Main Function for ECOM
def main():
    # Flags, a place to list your query, subject, output prefix, and number of threads
    parser = argparse.ArgumentParser(
        description="Ultra-fast 5-file EC analysis + prefix check (48-core optimized)"
    )
    parser.add_argument("query_csv", help="Path to query CSV in format Genus_Species_etc.csv and consisting of a list of EC numbers under the column header EC_ID")
    parser.add_argument("subject_dir", help="Directory with subject CSVs in format Genus_Species_etc.csv and consisting of a list of EC numbers under the column header EC_ID")
    parser.add_argument("--output", "-o", default="ec_analysis_prefix", help="Output prefix")
    parser.add_argument("--threads", "-t", type=int, default=48, help="Number of threads (default: 48)")
    args = parser.parse_args()

    # Load data supplied from flags
    query_ecs, subject_ecs, prefix_list = load_data(args.query_csv, args.subject_dir)
    files = list(subject_ecs.keys())

    # Sanity check for at least 5 EC files in subject folder, since the script is hardcoded to work on combinations of five subjects
    if len(files) < 5:
        print("Need at least 5 valid files!")
        sys.exit(1)

    # Total number of combinations possible from list of subject files
    total_combos = len(list(combinations(files, 5)))
    print(f"Evaluating {total_combos:,} combinations using {args.threads} threads...\n")

    # Total number of threads used in the program
    actual_threads = min(args.threads, cpu_count())
    print(f"Launching pool with {actual_threads} workers...\n")

    # Split assessment of combinations by number of threads available
    with Pool(processes=actual_threads,
              initializer=init_worker,
              initargs=(query_ecs, subject_ecs, prefix_list)) as pool:

        # Run combination function across available threads, display progress bar
        results = list(tqdm(
            pool.imap_unordered(evaluate_combo, combinations(files, 5)),
            total=total_combos,
            desc="Processing",
            smoothing=0.01
        ))

    # File creation variables
    df = pd.DataFrame(results)
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    prefix_out = args.output

    # Save all ranked tables with new column, each file has the same data, but is simply sorted differently and therefore ranked differently
    for name, sort_key, ascending, label in [
        ("A_best_query_coverage", "query_covered_fraction", False, "Best Query Coverage"),
        ("B_worst_query_coverage", "query_covered_fraction", True, "Worst Query Coverage"),
        ("C_most_diverse", "total_unique_ecs", False, "Most Diverse (Total Unique)"),
        ("D_most_redundant", "total_unique_ecs", True, "Most Redundant"),
    ]:
        ranked = df.sort_values(sort_key, ascending=ascending).reset_index(drop=True)
        ranked.index += 1
        ranked.to_csv(f"{prefix_out}_{name}_{timestamp}.csv", index_label="rank")

    # Create CSV files from dataframe, five files created in total 
    df.to_csv(f"{prefix_out}_ALL_combinations_{timestamp}.csv", index=False)

    # Summary of Analysis
    print(f"\nAnalysis Complete!")
    print(f"   Total combinations: {len(df):,}")
    print(f"   Results saved → {prefix_out}_*_{timestamp}.csv")

    print(f"\nTop results:")
    print(f"   Best query coverage : {df['query_covered_fraction'].max():.5f}")
    print(f"   Worst query coverage: {df['query_covered_fraction'].min():.5f}")
    print(f"   Most diverse combo  : {df['total_unique_ecs'].max():,} ECs")
    print(f"   Most redundant      : {df['total_unique_ecs'].min():,} ECs")


if __name__ == "__main__":
    main()
###################################################################################################################################################

###################################################################################################################################################
# End of script
