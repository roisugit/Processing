# 1. Install Nextflow (one-time)
curl -s https://get.nextflow.io | bash
sudo mv nextflow /usr/local/bin/

# 2. (Optional but recommended) Pull the latest workflow
nextflow pull epi2me-labs/wf-16s

# 3. Run it on your data
nextflow run epi2me-labs/wf-16s \
    --fastq "/path/to/your/fastq_directory" \
    --classifier minimap2 \
    --database_set ncbi_16s_18s \
    --outdir "./wf16s_results" \
    -profile standard \
    -resume
