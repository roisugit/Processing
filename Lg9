#!/usr/bin/env Rscript

library(tidyverse)

infile <- commandArgs(trailingOnly = TRUE)[1]
if (is.na(infile)) infile <- "input.tsv"

eps <- 1e-9

trend_levels <- c(
  "Increase, increase",
  "Decrease, decrease",
  "Increase, decrease",
  "Decrease, increase"
)

comparison_levels <- c(
  "D2-D0",
  "D7-D2",
  "D7-D0",
  "D2-D0 + D7-D2",
  "D2-D0 + D7-D0",
  "D7-D2 + D7-D0",
  "D2-D0 + D7-D2 + D7-D0"
)

# ---------- LOAD ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  mutate(
    Gene = as.character(Gene),
    D0 = as.numeric(D0),
    D2 = as.numeric(D2),
    D7 = as.numeric(D7),
    Combination = str_replace_all(as.character(Combination), "_", "-")
  )

# ---------- COLLAPSE BY GENE ----------
df_gene <- df %>%
  group_by(Gene) %>%
  summarise(
    D0 = first(D0),
    D2 = first(D2),
    D7 = first(D7),

    has_D2_D0 = any(Combination == "D2-D0"),
    has_D7_D2 = any(Combination == "D7-D2"),
    has_D7_D0 = any(Combination == "D7-D0"),

    .groups = "drop"
  ) %>%
  mutate(
    profile_id = row_number(),

    comparison_bin = case_when(
      has_D2_D0 & !has_D7_D2 & !has_D7_D0 ~ "D2-D0",
      !has_D2_D0 & has_D7_D2 & !has_D7_D0 ~ "D7-D2",
      !has_D2_D0 & !has_D7_D2 & has_D7_D0 ~ "D7-D0",

      has_D2_D0 & has_D7_D2 & !has_D7_D0 ~ "D2-D0 + D7-D2",
      has_D2_D0 & !has_D7_D2 & has_D7_D0 ~ "D2-D0 + D7-D0",
      !has_D2_D0 & has_D7_D2 & has_D7_D0 ~ "D7-D2 + D7-D0",

      has_D2_D0 & has_D7_D2 & has_D7_D0 ~ "D2-D0 + D7-D2 + D7-D0",

      TRUE ~ NA_character_
    ),

    d_D2_D0 = D2 - D0,
    d_D7_D2 = D7 - D2,

    trend_bin = case_when(
      d_D2_D0 > eps  & d_D7_D2 > eps  ~ "Increase, increase",
      d_D2_D0 < -eps & d_D7_D2 < -eps ~ "Decrease, decrease",
      d_D2_D0 > eps  & d_D7_D2 < -eps ~ "Increase, decrease",
      d_D2_D0 < -eps & d_D7_D2 > eps  ~ "Decrease, increase",
      TRUE ~ NA_character_
    )
  )

# ---------- FILTER / FACTOR ----------
df_unplotted <- df_gene %>%
  filter(is.na(trend_bin) | is.na(comparison_bin))

df_binned <- df_gene %>%
  filter(!is.na(trend_bin), !is.na(comparison_bin)) %>%
  mutate(
    trend_bin = factor(trend_bin, levels = trend_levels),
    comparison_bin = factor(comparison_bin, levels = comparison_levels)
  )

# ---------- LONG FORMAT ----------
long_df <- df_binned %>%
  select(profile_id, Gene, trend_bin, comparison_bin, D0, D2, D7) %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day = factor(day, levels = c("D0", "D2", "D7")),
    x = as.numeric(day)
  )

# ---------- LINE SEGMENTS ----------
segments_df <- bind_rows(
  df_binned %>%
    transmute(
      profile_id, Gene, trend_bin, comparison_bin,
      x = 1, xend = 2,
      y = D0, yend = D2
    ),
  df_binned %>%
    transmute(
      profile_id, Gene, trend_bin, comparison_bin,
      x = 2, xend = 3,
      y = D2, yend = D7
    )
)

# ---------- PANEL RANGES ----------
panel_ranges <- long_df %>%
  group_by(trend_bin, comparison_bin) %>%
  summarise(
    ymin = min(value, na.rm = TRUE),
    ymax = max(value, na.rm = TRUE),
    yrange = ymax - ymin,
    .groups = "drop"
  ) %>%
  mutate(
    yrange = if_else(yrange == 0, 1, yrange),
    bar_base = ymax + 0.20 * yrange,
    bar_step = 0.12 * yrange,
    tick = 0.06 * yrange
  )

# ---------- SIGNIFICANCE STAPLES ----------
sig_bars <- df_binned %>%
  distinct(trend_bin, comparison_bin) %>%
  left_join(panel_ranges, by = c("trend_bin", "comparison_bin")) %>%
  rowwise() %>%
  do({
    row <- .

    bars <- switch(
      as.character(row$comparison_bin),

      "D2-D0" = tibble(x = 1, xend = 2, level = 0),
      "D7-D2" = tibble(x = 2, xend = 3, level = 0),
      "D7-D0" = tibble(x = 1, xend = 3, level = 0),

      "D2-D0 + D7-D2" = tibble(
        x = c(1, 2),
        xend = c(2, 3),
        level = c(0, 1)
      ),

      "D2-D0 + D7-D0" = tibble(
        x = c(1, 1),
        xend = c(2, 3),
        level = c(0, 1)
      ),

      "D7-D2 + D7-D0" = tibble(
        x = c(2, 1),
        xend = c(3, 3),
        level = c(0, 1)
      ),

      "D2-D0 + D7-D2 + D7-D0" = tibble(
        x = c(1, 2, 1),
        xend = c(2, 3, 3),
        level = c(0, 1, 2)
      )
    )

    bars %>%
      mutate(
        trend_bin = row$trend_bin,
        comparison_bin = row$comparison_bin,
        y = row$bar_base + level * row$bar_step,
        tick = row$tick
      )
  }) %>%
  ungroup()

# ---------- PLOT ----------
p <- ggplot() +
  geom_segment(
    data = segments_df,
    aes(
      x = x, xend = xend,
      y = y, yend = yend,
      group = profile_id
    ),
    color = "gray",
    linewidth = 0.8,
    alpha = 0.85
  ) +
  geom_point(
    data = long_df,
    aes(
      x = x,
      y = value,
      group = profile_id
    ),
    color = "gray",
    size = 0.8,
    alpha = 0.85
  ) +

  geom_segment(
    data = sig_bars,
    aes(x = x, xend = xend, y = y, yend = y),
    color = "black",
    linewidth = 0.6
  ) +
  geom_segment(
    data = sig_bars,
    aes(x = x, xend = x, y = y, yend = y - tick),
    color = "black",
    linewidth = 0.6
  ) +
  geom_segment(
    data = sig_bars,
    aes(x = xend, xend = xend, y = y, yend = y - tick),
    color = "black",
    linewidth = 0.6
  ) +
  geom_text(
    data = sig_bars,
    aes(
      x = (x + xend) / 2,
      y = y + 0.5 * tick
    ),
    label = "*",
    size = 4
  ) +

  facet_grid(
    rows = vars(trend_bin),
    cols = vars(comparison_bin),
    drop = FALSE
  ) +

  scale_x_continuous(
    breaks = 1:3,
    labels = c("D0", "D2", "D7")
  ) +

  scale_y_continuous(
    breaks = function(x) seq(floor(min(x)), ceiling(max(x)), by = 1),
    expand = expansion(mult = c(0.05, 0.30))
  ) +

  theme_bw(base_size = 12) +
  theme(
    panel.grid.minor = element_blank(),
    strip.text = element_text(size = 8),
    legend.position = "none"
  ) +

  labs(
    x = NULL,
    y = "Log2-CPM"
  )

# ---------- OUTPUT ----------
ggsave("paneled_trend_plot.pdf", p, width = 24, height = 12)
ggsave("paneled_trend_plot.png", p, width = 24, height = 12, dpi = 300)

write_tsv(df_gene, "gene_combination_profiles.tsv")
write_tsv(df_binned, "binned_profiles.tsv")
write_tsv(segments_df, "binned_segments.tsv")
write_tsv(df_unplotted, "unplotted_profiles.tsv")
