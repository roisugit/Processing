import requests
import pandas as pd
import time

input_csv = "input_genes.csv"
output_csv = "cattle_ensembl_to_human_orthologs.csv"

df_in = pd.read_csv(input_csv)

# Column 13 = index 12
cattle_ensembl_ids = (
    df_in.iloc[:, 12]
    .dropna()
    .astype(str)
    .str.strip()
    .drop_duplicates()
    .tolist()
)

def get_json(url, method="GET", payload=None):
    headers = {
        "Content-Type": "application/json",
        "Accept": "application/json"
    }

    if method == "POST":
        r = requests.post(url, headers=headers, json=payload)
    else:
        r = requests.get(url, headers=headers)

    r.raise_for_status()
    return r.json()

rows = []

# Map cattle Ensembl IDs directly to human orthologs
for cattle_id in cattle_ensembl_ids:
    url = (
        f"https://rest.ensembl.org/homology/id/{cattle_id}"
        "?target_species=homo_sapiens;type=orthologues;format=full;sequence=none"
    )

    print(f"Processing: {cattle_id}")

    try:
        data = get_json(url)

        for item in data.get("data", []):
            for h in item.get("homologies", []):
                rows.append({
                    "input_cattle_ensembl": cattle_id,
                    "human_ensembl": h["target"]["id"],
                    "human_symbol": h["target"].get("display_id"),
                    "orthology_type": h.get("type"),
                    "human_perc_id": h["target"].get("perc_id")
                })

    except Exception as e:
        rows.append({
            "input_cattle_ensembl": cattle_id,
            "human_ensembl": None,
            "human_symbol": None,
            "orthology_type": "ERROR",
            "human_perc_id": None,
            "error": str(e)
        })

    time.sleep(0.1)

df = pd.DataFrame(rows)

# Optional: fill missing human symbols/descriptions from lookup/id
human_ids = df["human_ensembl"].dropna().drop_duplicates().tolist()

lookup = {}

for i in range(0, len(human_ids), 1000):
    batch = human_ids[i:i+1000]

    result = get_json(
        "https://rest.ensembl.org/lookup/id",
        method="POST",
        payload={"ids": batch}
    )

    lookup.update(result)
    time.sleep(0.1)

id_to_symbol = {
    k: v.get("display_name")
    for k, v in lookup.items()
    if isinstance(v, dict)
}

id_to_description = {
    k: v.get("description")
    for k, v in lookup.items()
    if isinstance(v, dict)
}

df["human_symbol"] = df["human_ensembl"].map(id_to_symbol)
df["human_description"] = df["human_ensembl"].map(id_to_description)

df.to_csv(output_csv, index=False)

print(df.head())
print(f"\nSaved results to: {output_csv}")
