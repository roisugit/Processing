import pandas as pd
from playwright.sync_api import sync_playwright
import urllib.parse
import os

def build_colored_kegg_url(map_id, ec_string):
    ec_list = [ec.strip() for ec in str(ec_string).split(';') if str(ec).strip()]
    if not ec_list:
        return None
    # High-visibility color: lime background + black text (impossible to miss)
    color_spec = "lime,black"
    query_parts = [f"{ec}+{color_spec}" for ec in ec_list]
    multi_query = "\r\n".join(query_parts)
    params = {'map': map_id, 'multi_query': multi_query}
    return "https://www.kegg.jp/kegg-bin/show_pathway?" + urllib.parse.urlencode(params)

def save_pathway_as_pdf(map_id, ec_string, row_num):
    print(f"\nRow {row_num}: Pathway ID = {map_id}")
    print(f"   Raw ECs (column 8): '{ec_string}'")
    ec_list = [ec.strip() for ec in str(ec_string).split(';') if str(ec).strip()]
    print(f"   Cleaned EC list: {ec_list}")
    if not ec_list:
        print("   Skipping - no EC numbers")
        return

    maps_to_try = [map_id]
    if map_id.startswith('map'):
        ec_map = 'ec' + map_id[3:]
        maps_to_try.append(ec_map)
        print(f"   Will also try EC-specific map: {ec_map}")

    for current_map in maps_to_try:
        url = build_colored_kegg_url(current_map, ec_string)
        if not url:
            continue
        print(f"   Trying map: {current_map} → {url}")
        output_pdf = f"{current_map}_highlighted.pdf"

        with sync_playwright() as p:
            browser = p.chromium.launch(headless=True)
            page = browser.new_page()
            page.goto(url, wait_until="networkidle")
            # Wait extra for the pathway image to fully render
            page.wait_for_timeout(3000)
            page.pdf(path=output_pdf, format="A4", print_background=True)
            browser.close()

        print(f"   ✓ Saved as PDF: {output_pdf} (lime highlight + full page layout)")
        print(f"   Open the PDF in any viewer — the highlighted EC boxes should be clearly visible.\n")
        break
    else:
        print("   ✗ Could not generate PDF for this pathway\n")

print("=== KEGG Pathway → PDF Highlighter (First 3 rows only) ===\n")
print("This uses the browser to render the exact colored map and exports it as PDF (your requested 'print to PDF' method).\n")

df = pd.read_csv("your_data.tsv", sep='\t')

for i, row in df.head(3).iterrows():
    map_id = str(row.iloc[1]).strip()
    ec_string = row.iloc[7]
    save_pathway_as_pdf(map_id, ec_string, i + 1)

print("\n✅ All done! Check the generated _highlighted.pdf files.")
print("If highlights are still missing even in the PDFs, the EC numbers in column 8 simply aren't present on that specific pathway map.")
