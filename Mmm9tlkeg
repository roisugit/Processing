import pandas as pd
import requests
from bs4 import BeautifulSoup
import urllib.parse
import re

def highlight_kegg_pathway(map_id, ec_string, row_num):
    print(f"\n=== Row {row_num} ===")
    print(f"Pathway ID = {map_id}")
    print(f"Raw EC string (column 8) = '{ec_string}'")
    
    # Split and clean every single item
    raw_items = [x.strip() for x in str(ec_string).split(';') if str(x).strip()]
    print(f"Split items ({len(raw_items)}): {raw_items}")
    
    # ULTRA-STRICT EC filter: ONLY full EC numbers like "1.2.3.4" (exactly 3 dots, 4 numbers, no "-")
    ec_list = []
    for item in raw_items:
        # Remove common prefixes
        cleaned = item.upper().replace("EC:", "").replace("EC ", "").strip()
        
        # Strict regex: must be exactly N.N.N.N where each N is 1-2 digits
        if re.match(r'^\d{1,2}\.\d{1,2}\.\d{1,2}\.\d{1,2}$', cleaned) and '-' not in cleaned:
            ec_list.append(cleaned)
        else:
            print(f"   REJECTED: '{item}' → does not match full EC pattern")
    
    ec_list = list(dict.fromkeys(ec_list))  # remove duplicates
    print(f"FINAL ECs that will be highlighted ({len(ec_list)}): {ec_list}")
    
    if not ec_list:
        print("   → Skipping: no valid full EC numbers found")
        return
    
    # Force EC-specific map (this is the correct one for EC highlighting)
    if map_id.startswith('map'):
        target_map = 'ec' + map_id[3:]
    else:
        target_map = map_id
    print(f"Using map: {target_map}")
    
    # Bright yellow + black text (very visible)
    color_spec = "yellow,black"
    query_parts = [f"{ec}+{color_spec}" for ec in ec_list]
    multi_query = "\r\n".join(query_parts)
    
    params = {'map': target_map, 'multi_query': multi_query}
    full_url = "https://www.kegg.jp/kegg-bin/show_pathway?" + urllib.parse.urlencode(params)
    print(f"Colored URL: {full_url}")
    
    headers = {'User-Agent': 'Mozilla/5.0'}
    response = requests.get("https://www.kegg.jp/kegg-bin/show_pathway", params=params, headers=headers)
    soup = BeautifulSoup(response.text, 'html.parser')
    img = soup.find('img', attrs={'usemap': True})
    if not img:
        img = soup.find('img', src=lambda x: x and '.png' in str(x).lower() if x else False)
    
    if img and img.get('src'):
        img_src = img['src']
        if not img_src.startswith('http'):
            img_src = 'https://www.kegg.jp' + (img_src if img_src.startswith('/') else '/' + img_src)
        output_file = f"{target_map}_highlighted.png"
        img_data = requests.get(img_src, headers=headers).content
        with open(output_file, 'wb') as f:
            f.write(img_data)
        print(f"   ✓ Saved: {output_file} (yellow highlight)\n")
    else:
        print(f"   ✗ Could not retrieve image\n")

print("=== ULTRA-STRICT KEGG HIGHLIGHTER (First 3 rows only) ===\n")
df = pd.read_csv("your_data.tsv", sep='\t')

for i, row in df.head(3).iterrows():
    map_id = str(row.iloc[1]).strip()
    ec_string = row.iloc[7]
    highlight_kegg_pathway(map_id, ec_string, i + 1)
