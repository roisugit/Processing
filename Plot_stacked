#!/usr/bin/env Rscript

library(tidyverse)

# ---------- FILES ----------
infile <- "gene_colors_with_log2fc_and_pathways.tsv"
group_file <- "pathway_groups.tsv"

outfile_png <- "reactome_pathway_dotplot_faceted.png"
outfile_pdf <- "reactome_pathway_dotplot_faceted.pdf"

# ---------- LOAD ----------
df <- read_tsv(infile, show_col_types = FALSE) %>%
  rename(Gene = 1, color = 2) %>%
  mutate(Gene = as.character(Gene), color = as.character(color))

pathway_groups <- read_tsv(group_file, show_col_types = FALSE) %>%
  rename(
    pathway = 1,
    pathway_group = 2
  ) %>%
  mutate(
    pathway = as.character(pathway),
    pathway_group = as.character(pathway_group)
  )

# ---------- LONG PATHWAY TABLE ----------
plot_df <- df %>%
  select(Gene, color, pathways_D2_v_D0, pathways_D7_v_D2, pathways_D7_v_D0) %>%
  pivot_longer(
    cols = starts_with("pathways_"),
    names_to = "comparison",
    values_to = "pathway"
  ) %>%
  filter(!is.na(pathway), pathway != "") %>%
  separate_rows(pathway, sep = ",") %>%
  mutate(pathway = str_trim(pathway)) %>%
  filter(pathway != "") %>%
  distinct(pathway, color, Gene) %>%
  count(pathway, color, name = "n_genes") %>%
  left_join(pathway_groups, by = "pathway") %>%
  mutate(
    pathway_group = replace_na(pathway_group, "Ungrouped")
  )

# ---------- ORDER PATHWAYS ----------
pathway_order <- plot_df %>%
  group_by(pathway) %>%
  summarise(total_genes = sum(n_genes), .groups = "drop") %>%
  arrange(desc(total_genes)) %>%
  pull(pathway)

# ---------- ORDER COLORS ----------
color_order <- plot_df %>%
  group_by(color) %>%
  summarise(total_genes = sum(n_genes), .groups = "drop") %>%
  arrange(desc(total_genes)) %>%
  pull(color)

plot_df <- plot_df %>%
  mutate(
    pathway = factor(pathway, levels = pathway_order),
    color = factor(color, levels = color_order)
  )

# ---------- COLOR MAP ----------
color_values <- levels(plot_df$color)
names(color_values) <- color_values

# ---------- PLOT ----------
p <- ggplot(plot_df, aes(x = pathway, y = color)) +
  geom_point(
    aes(size = n_genes, color = color),
    alpha = 0.9
  ) +
  facet_grid(
    cols = vars(pathway_group),
    scales = "free_x",
    space = "free_x"
  ) +
  scale_color_manual(values = color_values) +
  scale_size_continuous(name = "Unique genes") +
  guides(color = "none") +
  theme_bw(base_size = 12) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1, vjust = 1),
    axis.text.y = element_blank(),
    axis.ticks.y = element_blank(),
    axis.title.y = element_blank(),
    legend.position = "right",
    panel.grid.minor = element_blank(),
    strip.background = element_rect(fill = "grey90", color = "black"),
    strip.text.x = element_text(size = 10),
    plot.margin = margin(t = 10, r = 10, b = 10, l = 60)
  ) +
  labs(
    x = "Reactome pathway",
    y = NULL
  )

# ---------- SAVE ----------
ggsave(outfile_png, p, width = 16, height = 7, dpi = 300)
ggsave(outfile_pdf, p, width = 16, height = 7)
