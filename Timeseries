message("Main DEG gene list: maSigPro_DEG_gene_list.csv")
message("Full DEG table/object: maSigPro_DEGs_full_table.csv and maSigPro_DEGs_full_object.rds")
message("Model coefficients: maSigPro_model_coefficients_all_selected_genes.csv")
