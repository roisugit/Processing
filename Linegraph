# Load required libraries
library(tidyverse)

# Read the TSV file
df <- read_tsv("your_file.tsv")

# Add unique panel ID, but display only COUNT
df <- df %>%
  mutate(
    row_id = row_number(),
    panel_label = paste0("Count: ", COUNT),
    panel_id = factor(row_id, levels = row_id)
  )

# Reshape from wide to long format
long_df <- df %>%
  pivot_longer(
    cols = c(D0, D2, D7),
    names_to = "day",
    values_to = "value"
  ) %>%
  mutate(
    day_num = as.numeric(str_remove(day, "D"))
  )

# Custom facet labels: unique panels, count-only labels
count_labels <- setNames(df$panel_label, df$panel_id)

# Create the paneled dot + line plot
p <- ggplot(long_df, aes(x = day_num, y = value, group = row_id)) +
  geom_line() +
  geom_point(size = 2) +
  facet_wrap(
    ~ panel_id,
    ncol = 6,
    labeller = labeller(panel_id = count_labels)
  ) +
  scale_x_continuous(breaks = c(0, 2, 7)) +
  labs(
    x = "Day",
    y = "Value",
    title = "Day 0, 2, and 7 Values"
  ) +
  theme_bw()

print(p)

ggsave("paneled_plot.png", plot = p, width = 12, height = 10, dpi = 300)
