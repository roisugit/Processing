# =========================================================
# Compact polished GO summary plot
# GO term | log2 Fold Enrichment | gene-group dots | top genes
# =========================================================

library(tidyverse)
library(ggtext)
library(scales)
library(ggnewscale)

# =========================================================
# USER SETTINGS
# =========================================================

datasets <- tribble(
  ~comparison,    ~direction, ~go_file,              ~gene_file,
  "comparison_1", "up",       "comp1_up_GO.csv",     "comp1_up_genes.csv",
  "comparison_1", "down",     "",                    "",
  "comparison_2", "up",       "comp2_up_GO.csv",     "comp2_up_genes.csv",
  "comparison_2", "down",     "comp2_down_GO.csv",   "comp2_down_genes.csv",
  "comparison_3", "up",       "",                    "",
  "comparison_3", "down",     "comp3_down_GO.csv",   "comp3_down_genes.csv"
)

facet_file <- "GO_facets.tsv"

# TSV:
# gene_id    hex_color
gene_color_file <- "gene_colors.tsv"

output_dir <- "heatmap_outputs"
dir.create(output_dir, showWarnings = FALSE)

GO_LOG2FE_THRESHOLD <- 3
SIGN_GO_BY_DIRECTION <- TRUE
TOP_N_GENES <- 5

# =========================================================
# COLUMN SETTINGS
# =========================================================

GO_TERM_COL <- 2
GO_GENES_COL <- 11
GO_LOG2FE_COL <- 12

GENE_ID_COL <- 1
GENE_LOG2FC_COL <- 2

FACET_GO_TERM_COL <- 1
FACET_GROUP_COL <- 2

# =========================================================
# LOAD FACETS
# =========================================================

facet_df <- read_tsv(
  facet_file,
  show_col_types = FALSE
) %>%
  select(
    go_term = all_of(FACET_GO_TERM_COL),
    facet = all_of(FACET_GROUP_COL)
  ) %>%
  mutate(
    go_term = as.character(go_term),
    facet = as.character(facet)
  )

# =========================================================
# LOAD GENE COLORS
# =========================================================

gene_color_df <- read_tsv(
  gene_color_file,
  show_col_types = FALSE
) %>%
  select(
    gene_id = 1,
    hex_color = 2
  ) %>%
  mutate(
    gene_id = as.character(gene_id),
    hex_color = as.character(hex_color)
  )

# =========================================================
# PARSE FILES
# =========================================================

go_long_list <- list()
gene_long_list <- list()
go_gene_list <- list()

for (i in seq_len(nrow(datasets))) {

  comparison <- datasets$comparison[i]
  direction <- datasets$direction[i]
  go_file <- datasets$go_file[i]
  gene_file <- datasets$gene_file[i]

  if (is.na(go_file) || is.na(gene_file) || go_file == "" || gene_file == "") {
    message("Skipping ", comparison, " ", direction)
    next
  }

  if (!file.exists(go_file) || !file.exists(gene_file)) {
    message("Skipping missing files: ", comparison, " ", direction)
    next
  }

  dataset_name <- paste(comparison, direction, sep = "_")

  go_df <- read_csv(go_file, show_col_types = FALSE)
  gene_df <- read_csv(gene_file, show_col_types = FALSE)

  gene_long <- gene_df %>%
    select(
      gene_id = all_of(GENE_ID_COL),
      gene_log2FC = all_of(GENE_LOG2FC_COL)
    ) %>%
    mutate(
      gene_id = as.character(gene_id),
      gene_log2FC = as.numeric(gene_log2FC),
      comparison = comparison
    )

  gene_long_list[[dataset_name]] <- gene_long

  go_long <- go_df %>%
    transmute(
      go_term = as.character(.data[[names(go_df)[GO_TERM_COL]]]),
      gene_list = as.character(.data[[names(go_df)[GO_GENES_COL]]]),
      go_log2FC = as.numeric(.data[[names(go_df)[GO_LOG2FE_COL]]]),
      comparison = comparison
    ) %>%
    mutate(
      go_log2FC = case_when(
        SIGN_GO_BY_DIRECTION & direction == "down" ~ -abs(go_log2FC),
        SIGN_GO_BY_DIRECTION & direction == "up" ~ abs(go_log2FC),
        TRUE ~ go_log2FC
      )
    ) %>%
    filter(
      !is.na(go_log2FC),
      is.finite(go_log2FC),
      abs(go_log2FC) >= GO_LOG2FE_THRESHOLD
    )

  go_long_list[[dataset_name]] <- go_long %>%
    select(-gene_list)

  go_gene_links <- go_long %>%
    separate_rows(gene_list, sep = ",") %>%
    mutate(gene_id = str_trim(gene_list)) %>%
    filter(
      !is.na(gene_id),
      gene_id != "",
      tolower(gene_id) != "nan"
    ) %>%
    select(
      comparison,
      go_term,
      gene_id
    )

  go_gene_list[[dataset_name]] <- go_gene_links
}

# =========================================================
# COMBINE DATA
# =========================================================

go_long <- bind_rows(go_long_list) %>%
  left_join(facet_df, by = "go_term") %>%
  mutate(
    facet = replace_na(facet, "Unannotated")
  )

gene_long <- bind_rows(gene_long_list) %>%
  group_by(gene_id) %>%
  summarise(
    gene_log2FC = mean(gene_log2FC, na.rm = TRUE),
    .groups = "drop"
  )

go_gene_long <- bind_rows(go_gene_list) %>%
  distinct() %>%
  left_join(
    go_long %>%
      select(
        comparison,
        go_term,
        go_log2FC,
        facet
      ),
    by = c("comparison", "go_term")
  ) %>%
  filter(
    !is.na(go_term),
    !is.na(facet)
  )

merged <- go_gene_long %>%
  left_join(gene_long, by = "gene_id") %>%
  left_join(gene_color_df, by = "gene_id")

# =========================================================
# GENE UNIQUENESS
# =========================================================

gene_uniqueness <- go_gene_long %>%
  distinct(go_term, gene_id) %>%
  count(gene_id, name = "go_occurrences")

# =========================================================
# TOP GENES
# =========================================================

top_gene_labels <- merged %>%
  filter(!is.na(gene_log2FC)) %>%
  group_by(
    comparison,
    facet,
    go_term
  ) %>%
  arrange(desc(gene_log2FC), .by_group = TRUE) %>%
  slice_head(n = TOP_N_GENES) %>%
  ungroup() %>%
  left_join(gene_uniqueness, by = "gene_id") %>%
  mutate(

    gene_color = ifelse(
      is.na(hex_color),
      "#000000",
      hex_color
    ),

    color_dot = ifelse(
      !is.na(hex_color),
      paste0(
        "<span style='color:",
        gene_color,
        "; font-size:13pt;'>●</span>"
      ),
      ""
    ),

    gene_label = case_when(

      # UNIQUE GENES
      go_occurrences == 1 ~
        paste0(
          "<b><i>",
          gene_id,
          "</i></b> ",
          color_dot
        ),

      # NON-UNIQUE GENES
      TRUE ~
        paste0(
          "<i>",
          gene_id,
          "</i> ",
          color_dot
        )
    )
  ) %>%
  group_by(
    comparison,
    facet,
    go_term
  ) %>%
  summarise(
    top_genes = paste(gene_label, collapse = ", "),
    .groups = "drop"
  )

# =========================================================
# PLOT DATA
# =========================================================

plot_data <- go_long %>%
  left_join(
    top_gene_labels,
    by = c(
      "comparison",
      "facet",
      "go_term"
    )
  ) %>%
  mutate(
    top_genes = replace_na(top_genes, ""),
    abs_go_log2FC = abs(go_log2FC),

    comparison_label = str_replace(
      comparison,
      "comparison_",
      "comm"
    )
  ) %>%
  arrange(
    facet,
    comparison,
    desc(abs_go_log2FC)
  ) %>%
  group_by(facet) %>%
  mutate(go_order = row_number()) %>%
  ungroup() %>%
  mutate(
    go_term_wrapped = str_wrap(go_term, width = 38),

    go_term_factor = factor(
      paste(
        facet,
        go_order,
        comparison,
        go_term_wrapped,
        sep = "___"
      ),
      levels = rev(
        paste(
          facet,
          go_order,
          comparison,
          go_term_wrapped,
          sep = "___"
        )
      )
    )
  )

# =========================================================
# NUMERIC Y POSITIONS
# =========================================================

plot_data <- plot_data %>%
  mutate(
    y_pos = rev(seq_len(n()))
  )

# =========================================================
# BAR POSITIONS
# =========================================================

max_abs_go <- max(
  plot_data$abs_go_log2FC,
  na.rm = TRUE
)

plot_data <- plot_data %>%
  mutate(
    bar_x_start = 1.05,

    bar_x_end = 1.05 + rescale(
      abs_go_log2FC,
      to = c(0.04, 0.62),
      from = c(0, max_abs_go)
    )
  )

# =========================================================
# DOT PANEL DATA
# =========================================================

dot_data <- merged %>%
  filter(!is.na(hex_color)) %>%
  group_by(
    comparison,
    facet,
    go_term,
    hex_color
  ) %>%
  summarise(
    color_gene_count = n_distinct(gene_id),
    .groups = "drop"
  ) %>%
  left_join(
    plot_data %>%
      select(
        comparison,
        facet,
        go_term,
        y_pos
      ),
    by = c(
      "comparison",
      "facet",
      "go_term"
    )
  ) %>%
  group_by(
    comparison,
    facet,
    go_term
  ) %>%
  arrange(hex_color, .by_group = TRUE) %>%
  mutate(
    dot_index = row_number(),

    dot_x = 1.82 + (dot_index - 1) * 0.032
  ) %>%
  ungroup()

# =========================================================
# COMPARISON BRACKET LABELS
# =========================================================

comparison_brackets <- plot_data %>%
  group_by(
    facet,
    comparison_label
  ) %>%
  summarise(
    ymin = min(y_pos),
    ymax = max(y_pos),
    ymid = mean(c(ymin, ymax)),
    .groups = "drop"
  )

# =========================================================
# SINGLE PLOT
# =========================================================

single_plot <- ggplot(
  plot_data,
  aes(y = y_pos)
) +

  # comparison brackets
  geom_segment(
    data = comparison_brackets,
    aes(
      x = 0.08,
      xend = 0.08,
      y = ymin,
      yend = ymax
    ),
    linewidth = 0.7,
    inherit.aes = FALSE
  ) +

  geom_segment(
    data = comparison_brackets,
    aes(
      x = 0.08,
      xend = 0.12,
      y = ymin,
      yend = ymin
    ),
    linewidth = 0.7,
    inherit.aes = FALSE
  ) +

  geom_segment(
    data = comparison_brackets,
    aes(
      x = 0.08,
      xend = 0.12,
      y = ymax,
      yend = ymax
    ),
    linewidth = 0.7,
    inherit.aes = FALSE
  ) +

  # comparison labels
  geom_text(
    data = comparison_brackets,
    aes(
      x = 0.055,
      y = ymid,
      label = comparison_label
    ),
    fontface = "bold",
    hjust = 1,
    size = 2.4,
    inherit.aes = FALSE
  ) +

  # GO term
  geom_text(
    aes(
      x = 0.92,
      y = y_pos,
      label = go_term_wrapped
    ),
    hjust = 1,
    size = 2.5,
    lineheight = 0.78
  ) +

  # log2FE bar
  geom_segment(
    aes(
      x = bar_x_start,
      xend = bar_x_end,
      y = y_pos,
      yend = y_pos,
      color = abs_go_log2FC
    ),
    linewidth = 5.5,
    lineend = "round"
  ) +

  scale_color_gradient(
    low = "#B7D4F0",
    high = "#08306B",
    name = "log2 Fold Enrichment"
  ) +

  ggnewscale::new_scale_color() +

  # colored gene-group dots
  geom_point(
    data = dot_data,
    aes(
      x = dot_x,
      y = y_pos,
      size = color_gene_count
    ),
    shape = 16,
    color = dot_data$hex_color,
    stroke = 0,
    alpha = 0.98
  ) +

  scale_size_continuous(
    name = "Genes per group",
    range = c(2.2, 6.2)
  ) +

  # top genes
  ggtext::geom_richtext(
    aes(
      x = 2.22,
      y = y_pos,
      label = top_genes
    ),
    hjust = 0,
    fill = NA,
    label.color = NA,
    size = 2.45,
    lineheight = 1.15
  ) +

  facet_grid(
    facet ~ .,
    scales = "free_y",
    space = "free_y",
    switch = "y"
  ) +

  scale_y_continuous(
    breaks = plot_data$y_pos,
    labels = rep("", nrow(plot_data)),
    expand = expansion(add = c(1.1, 1.1))
  ) +

  scale_x_continuous(
    limits = c(0.0, 3.7),

    breaks = c(
      0.10,
      1.22,
      1.95,
      2.85
    ),

    labels = c(
      "",
      "log2 Fold Enrichment",
      "Groups",
      "Top genes"
    ),

    expand = expansion(mult = c(0.01, 0.01))
  ) +

  labs(
    x = NULL,
    y = NULL
  ) +

  coord_cartesian(
    clip = "off"
  ) +

  theme_minimal(base_size = 10) +

  theme(

    panel.grid = element_blank(),

    panel.border = element_rect(
      color = "grey35",
      fill = NA,
      linewidth = 0.6
    ),

    strip.placement = "outside",

    strip.background.y = element_rect(
      fill = "grey90",
      color = "grey35",
      linewidth = 0.6
    ),

    strip.text.y.left = element_text(
      angle = 90,
      face = "bold",
      size = 10,
      color = "black",
      margin = margin(3, 3, 3, 3)
    ),

    axis.text.y = element_blank(),
    axis.ticks = element_blank(),

    axis.text.x = element_text(
      face = "bold",
      size = 9,
      color = "black"
    ),

    plot.margin = margin(
      8,
      10,
      8,
      35
    ),

    panel.spacing.y = unit(0.7, "lines"),

    legend.position = "right",

    legend.title = element_text(
      face = "bold",
      size = 9
    ),

    legend.text = element_text(
      size = 8
    )
  )

# =========================================================
# SAVE PNG
# =========================================================

png(
  file.path(
    output_dir,
    "single_GO_summary_plot_compact.png"
  ),
  width = 3200,
  height = max(
    2200,
    65 * nrow(plot_data)
  ),
  res = 240
)

print(single_plot)

dev.off()

# =========================================================
# SAVE PDF
# =========================================================

pdf(
  file.path(
    output_dir,
    "single_GO_summary_plot_compact.pdf"
  ),
  width = 15,
  height = max(
    9,
    0.34 * nrow(plot_data)
  )
)

print(single_plot)

dev.off()

# =========================================================
# SAVE TABLES
# =========================================================

write_csv(
  go_long,
  file.path(
    output_dir,
    "parsed_GO_terms_combined.csv"
  )
)

write_csv(
  gene_long,
  file.path(
    output_dir,
    "parsed_gene_log2FC_combined.csv"
  )
)

write_csv(
  merged,
  file.path(
    output_dir,
    "GO_gene_combined_long.csv"
  )
)

write_csv(
  plot_data,
  file.path(
    output_dir,
    "single_GO_summary_plot_data.csv"
  )
)

write_csv(
  dot_data,
  file.path(
    output_dir,
    "GO_dot_panel_data.csv"
  )
)

message(
  "Done. Plot saved in: ",
  output_dir
)
